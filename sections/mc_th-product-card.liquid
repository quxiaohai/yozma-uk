            font-size: 1.0810810811vw;
        }
        .mc_th-product-card .product-content {
            padding: 2.8378378378vw 4.0540540541vw 2.8378378378vw 0;
        }
        .mc_th-product-card .product-content .product-name {
            font-size: 2.4324324324vw;
        }
        .mc_th-product-card .product-content .product-desc {
            font-size: 1.3513513514vw;
        }
        .mc_th-product-card .product-content .price-box {
            padding-top: 0.8108108108vw;
        }
        .mc_th-product-card .product-content .price-box .price {
            font-size: 1.6216216216vw;
        }
        .mc_th-product-card .product-content .price-box .original-price {
            font-size: 1.0810810811vw;
            padding-left: 0.5405405405vw;
        }
        .mc_th-product-card .btn-group .quantity-selector {
            min-width: 11.8243243243vw;
            height: 3.7162162162vw;
        }
        .mc_th-product-card .btn-group .quantity-selector .quantity-selector__input {
            font-size: 1.6216216216vw;
        }
        .mc_th-product-card .btn-group .button {
            height: 3.7162162162vw;
            font-size: 1.6216216216vw;
        }
