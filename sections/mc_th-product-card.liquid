    {% render 'page-wrap-style', info: ss %}
</style>
<section class="mc_th-product-card section--page" id="{{ section.id }}-card">
    {%- render 'section-title', info: ss -%}
    <div class="card-content flex-center-col w-full page-width">
        {%- for block in section.blocks -%}
            {%- liquid
                assign bs = block.settings
                assign product = bs.product
                assign variant = product.selected_or_first_available_variant
                assign options_size = product.options_with_values.size
                assign option = product.options_with_values[0]
                assign index = forloop.index0
                assign featured_image = product.featured_image | default: variant.featured_image
            -%}
            <div class="product-wrapper relative w-full overflow-hidden flex-between">
                {%- render 'global-image',
                    desktop_img: ss.desktop_image,
                    desktop_class: 'backdrop-image',
                    desktop_size: 1400,
                    mobile_img: ss.mobile_image,
                    desktop_size: 750
                -%}
                <a href="{{ product.url }}" class="product-cover overflow-hidden relative"
                   node-name="cover{{ index }}"
                   style="--object-fit: {{ bs.object_fit }};">
                    <div class="tag-items z-2 absolute flex-left">
                        {%- if bs.show_tag and bs.tag_text != blank -%}
                            <span class="tag fw-700 lh-2">{{ bs.tag_text }}</span>
                        {%- endif -%}
                        {%- if bs.show_saved and variant.compare_at_price > variant.price -%}
                            {%- assign diff = variant.compare_at_price | minus: variant.price -%}
                            <span class="tag fw-700 saved lh-2">Save {{ diff | money_without_trailing_zeros }}</span>
                        {%- endif -%}
                    </div>
                    {%- if bs.pc_product_image != blank -%}
                        {% render 'global-image',
                            desktop_img: bs.pc_product_image,
                            desktop_class: 'cover-image',
                            desktop_size: 750
                        %}
                    {%- else -%}
                        {% render 'global-image', desktop_img: featured_image, desktop_size: 750, desktop_class: 'cover-image' %}
                    {%- endif -%}
                    <div class="scene-wrap absolute z-1">
                        {%- render 'global-image', image: bs.pc_scene_image, image_size: 750 -%}
                    </div>
                </a>
                <div class="product-content relative">
                    <a href="{{ bs.product.url }}" class="product-name italic lh-2 fw-700">{{ bs.product.title }}</a>
                    <div
                        class="product-desc lh-2">{{ bs.product_description | default: product.description | truncate: 50 }}</div>
                    <div class="price-box flex-left">
                        <div node-name="price{{ index }}"
                             class="price lh-2 fw-700">{{ variant.price | money }}</div>
                        <div node-name="original{{ index }}"
                             class="original-price lh-5">{{ variant.compare_at_price | money }}</div>
                    </div>
                    {%- if options_size > 0 -%}
                        <div class="variant-selects">
                            {%- render 'choose-variant',
                                product: bs.product,
                                selector_style: ss.variant_type,
                                variant_limit: ss.variant_limit,
                                hide_label: true,
                                index: index,
                                emit: emit
                            -%}
                        </div>
                    {%- endif -%}
                    {%- assign specs = bs.product.metafields.custom.specifications.value -%}
                    {%- if specs != blank -%}
                        <ul class="text-items w-full flex-left">
                            {% for i in ( 0..specs.title_list.value.size ) limit: 4 %}
                                {% if specs.title_list.value[i] != blank %}
                                    <li class="text-item flex-center-col">
                                        {% for url in specs.icon_list.value %}
                                            {% assign i_2 = forloop.index | minus: 1 %}
                                            {% if i_2 == i and url != blank %}
                                                {%- render 'global-image', image: url, media_type: 'icon' -%}
                                            {% endif %}
                                        {% endfor %}
                                        <div class="num fw-700 italic lh-1">{{ specs.title_list.value[i] }}</div>
                                        <div class="text lh-2">{{ specs.content_list.value[i] }}</div>
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    {%- endif -%}
                    <div class="btn-group flex-between">
                        <div class="buy-box w-full flex-between">
                            <quantity-selector class="quantity-selector">
                                <button type="button" class="quantity-selector__button" aria-label="Decrease quantity">
                                    <svg role="presentation" focusable="false" width="10" height="2"
                                         class="icon icon-minus" viewBox="0 0 10 2">
                                        <path d="M0 0H10V2H0V0Z" fill="currentColor"></path>
                                    </svg>
                                </button>
                                <input
                                    type="number"
                                    is="quantity-input"
                                    node-name="quantity{{ index }}"
                                    inputmode="numeric"
                                    class="quantity-selector__input fw-600"
                                    name="quantity"
                                    value="1"
                                    step="1"
                                    min="1"
                                    autocomplete="off"
                                />
                                <button type="button" class="quantity-selector__button" aria-label="Increase quantity">
                                    <svg role="presentation" focusable="false" stroke-width="2" width="10" height="10"
                                         class="icon icon-plus" viewBox="0 0 12 12">
                                        <path d="M6 0V12" fill="none" stroke="currentColor"></path>
                                        <path d="M0 6L12 6" fill="none" stroke="currentColor"></path>
                                    </svg>
                                </button>
                            </quantity-selector>
                            <button
                                data-proxy="buy"
                                node-name="buy{{ index }}"
                                data-variant="{{ variant.id }}"
                                data-index="{{ index }}"
                                is="custom-button"
                                    class="button relative fw-600 flex-center">
                                <span class="btn-text">{{ bs.buy }}</span>
                            </button>
                        </div>
                        <button
                            is="hover-button"
                            data-proxy="cart"
                            node-name="cart{{ index }}"
                            data-variant="{{ variant.id }}"
                            data-index="{{ index }}"
                            class="button relative fw-600 flex-center">
                            <span class="btn-text">
                                {{ bs.checkout }}
                            </span>
                        </button>
                    </div>
                </div>
            </div>
        {%- endfor -%}
    </div>
</section>
<script>
    $heybike.ready(() => {
        const node = document.getElementById('{{ section.id }}-card');
        const nodeList = $heybike.getNodeList(node);
        $heybike.proxy(node, ['buy', 'cart'], ({elem, type}) => {
            $heybike.addToCart({
                items: [{
                    quantity: nodeList[`quantity${elem.dataset.index}`].value,
                    id: elem.dataset.variant
                }],
                button: elem
            }, type === 'buy')
        });
        $heybike.bind('{{ emit }}', option => {
            const index = option.index;
            if (!nodeList[`image${index}`]) {
                const image = document.createElement("img");
                image.classList.add("image");
                image.style.objectFit = "contain";
                nodeList[`cover${index}`].querySelector('.cover-image').replaceWith(image);
                nodeList[`image${index}`] = image;
            }
            nodeList[`image${index}`].src = option.image;
            nodeList[`price${index}`].textContent = option.price;
            nodeList[`original${index}`].textContent = option.originalPrice;
            nodeList[`buy${index}`].dataset.variant = option.id;
            nodeList[`cart${index}`].dataset.variant = option.id;
            nodeList[`buy${index}`].disabled = option.disabled;
            nodeList[`cart${index}`].disabled = option.disabled;
        });
    });
</script>
{% schema %}
{
  "name": "MC Th Product Card",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Th Product Card"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
