{%- liquid
    assign cid = section.id | split: '__' | last
    assign ss = section.settings
    assign emit = cid | append: ':variant:change'
-%}
<style>
    .mc_th-product-card {
        padding: 40px 0;
        background-color: #000000;
    }
    .mc_th-product-card .card-content {
        gap: 24px 0;
    }
    .mc_th-product-card .product-wrapper {
        background-color: #ffffff;
        gap: 70px;
        max-width: 1400px;
        align-items: stretch;
    }
    .mc_th-product-card .product-wrapper:before {
        content: "";
        width: 100%;
        height: 10px;
        position: absolute;
        left: 0;
        top: 0;
        background: #d30000;
        z-index: 2;
    }
    .mc_th-product-card .backdrop-image {
        position: absolute;
        top: 0;
        left: 0;
    }
    .mc_th-product-card .product-cover,
    .mc_th-product-card .product-content {
        width: 50%;
    }
    .mc_th-product-card .product-cover:hover .scene-wrap {
        opacity: 1;
    }
    .mc_th-product-card .product-cover:hover > .image {
        transform: scale(1.05);
    }
    .mc_th-product-card .product-cover .scene-wrap {
        height: 100%;
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
    }
    .mc_th-product-card .product-cover .scene-wrap .image {
        object-fit: cover;
    }
    .mc_th-product-card .product-cover .tag-items {
        left: 16px;
        top: 20px;
        gap: 8px;
    }
    .mc_th-product-card .product-cover .scene-wrap {
        left: 0;
        top: 0;
    }
    .mc_th-product-card .product-cover .tag {
        font-size: 14px;
        padding: 3px 9px;
        color: #39b359;
        background: #ebf7ee;
        border: 1px solid #bee5c8;
    }
    .mc_th-product-card .product-cover .tag.saved {
        color: #ff6312;
        background: #fff9ef;
        border: 1px solid #faead6;
    }
    .mc_th-product-card .product-cover .image {
        aspect-ratio: 4/3;
        object-fit: contain;
        transition: transform 0.3s ease-in-out;
    }
    .mc_th-product-card .text-items {
        padding: 40px 0;
        gap: 0 60px;
    }
    .mc_th-product-card .text-items .image {
        width: 48px;
        height: 48px;
        object-fit: contain;
    }
    .mc_th-product-card .text-items .text-item {
        color: #000000;
    }
    .mc_th-product-card .text-items .text-item .num {
        padding-top: 16px;
        font-size: 24px;
    }
    .mc_th-product-card .text-items .text-item .text {
        padding-top: 2px;
        font-size: 16px;
    }
    .mc_th-product-card .product-content {
        padding: 42px 60px 42px 0;
    }
    .mc_th-product-card .product-content .product-name {
        font-size: 36px;
        color: #000000;
    }
    .mc_th-product-card .product-content .product-desc {
        font-size: 20px;
    }
    .mc_th-product-card .product-content .price-box {
        padding-top: 12px;
    }
    .mc_th-product-card .product-content .price-box .price {
        font-size: 24px;
        color: #000000;
    }
    .mc_th-product-card .product-content .price-box .original-price {
        color: #999999;
        font-size: 1rem;
        text-decoration: line-through;
        padding-left: 8px;
        font-weight: 300;
    }
    .mc_th-product-card .btn-group {
        gap: 10px;
        flex-wrap: wrap;
    }
    .mc_th-product-card .btn-group .buy-box {
        gap: 10px;
    }
    .mc_th-product-card .btn-group .buy-box .button {
        --button-background-primary: 211 0 0;
    }
    .mc_th-product-card .btn-group .quantity-selector {
        min-width: 175px;
        height: 55px;
        border-radius: 0;
    }
    .mc_th-product-card .btn-group .quantity-selector .quantity-selector__button {
        transition: background-color 0.3s;
        transition-property: background-color, color;
    }
    .mc_th-product-card .btn-group .quantity-selector .quantity-selector__button:hover {
        background-color: #000000;
        color: #ffffff;
    }
    .mc_th-product-card .btn-group .quantity-selector .quantity-selector__input {
        flex: 1;
        font-size: 24px;
    }
    .mc_th-product-card .btn-group .quantity-selector .icon-minus {
        width: 10px;
        height: 10px;
    }
    .mc_th-product-card .btn-group .quantity-selector .icon-plus {
        width: 14px;
        height: 14px;
    }
    .mc_th-product-card .btn-group .button {
        padding: 0;
        height: 55px;
        width: 100%;
        font-size: 24px;
        border-radius: 0;
        color: #ffffff;
        transition: background 0.3s ease-in-out;
    }
    .mc_th-product-card .btn-group .button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    .mc_th-product-card .btn-group .button:not([disabled]):hover {
        background: #000000;
        color: #ffffff;
    }
    .mc_th-product-card .variant-selects {
        padding-top: 32px;
    }
    .mc_th-product-card .variant-picker__option {
        gap: 12px;
    }
    .mc_th-product-card .variant-picker__option .variant-picker__option-values {
        flex-wrap: wrap;
    }
    .mc_th-product-card .variant-picker__option input:checked + .block-swatch {
        box-shadow: inset 0 0 0 1px #000000;
        color: #000;
    }
    .mc_th-product-card .variant-picker__option .block-swatch {
        color: #747474;
        transition: box-shadow 0.3s;
        transition-property: box-shadow, color;
        padding: 1px 20px;
        box-shadow: inset 0 0 0 1px #747474;
        font-size: 20px;
        border-radius: 0;
        height: auto;
    }
    .mc_th-product-card .variant-picker__option .block-swatch:before {
        display: none;
    }
