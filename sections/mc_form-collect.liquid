{% assign ss = section.settings %}
<style>
    .mc_form-collect {
        padding: 80px 0;
    }

    .mc_form-collect .title {
        color: #181623;
        font-size: 50px;
        font-weight: 700;
        text-align: center;
        line-height: 1.18;
    }

    .mc_form-collect .form-content {
        max-width: 1000px;
        width: 100%;
        margin: 0 auto;
    }

    .mc_form-collect .form-content .form-head {
        font-weight: 700;
        font-size: 20px;
        color: #2d2d2d;
        padding: 24px 0;
        border-bottom: 1px solid #f2f2f2;
        line-height: 1.1;
    }

    .mc_form-collect .form-content .tip {
        font-size: 14px;
        color: #afb1b4;
        padding-bottom: 14px;
        word-break: break-word;
    }

    .mc_form-collect .form-content .sub-form {
        margin-top: 32px;
        padding: 16px 40px 48px;
        background: #fff;
        border-radius: 12px;
    }

    .mc_form-collect .form-content .sub-form > .tip {
        padding-top: 6px;
        padding-bottom: 0;
    }

    .mc_form-collect .form-content .sub-form .form-body {
        width: 100%;
        color: #181623;
        flex-wrap: wrap;
    }

    .mc_form-collect .form-content .sub-form .form-item {
        padding-top: 40px;
        width: calc(50% - 10px);
        position: relative;
    }

    .mc_form-collect .form-content .sub-form .form-item.fill {
        width: 100%;
    }

    .mc_form-collect .form-content .sub-form .form-item.error .required {
        transform: translateY(0);
        opacity: 1;
    }

    .mc_form-collect .form-content .sub-form .form-item.error .input,
    .mc_form-collect .form-content .sub-form .form-item.error .file {
        border-color: #f00;
    }

    .mc_form-collect .form-content .sub-form .form-item .name {
        font-size: 14px;
        font-weight: 700;
        line-height: 1.667;
        padding-bottom: 10px;
    }

    .mc_form-collect .form-content .sub-form .form-item .name sup {
        display: inline-block;
        transform: translateY(5px);
        color: #f00;
    }

    .mc_form-collect .form-content .sub-form .form-item .required {
        color: #f00;
        position: absolute;
        font-size: 12px;
        margin-top: 4px;
        opacity: 0;
        transform: translateY(-4px);
        transition: opacity 0.3s;
        transition-property: opacity, transform;
    }

    .mc_form-collect .form-content .sub-form .form-item .text {
        display: block;
    }

    .mc_form-collect .form-content .sub-form .form-item .radio-group {
        gap: 12px 20px;
    }

    .mc_form-collect .form-content .sub-form .form-item .radio {
        cursor: pointer;
        width: calc(25% - 15px);
        line-height: 1.2;
        height: 48px;
        border-radius: 6px;
        border: 1px solid #e8e8e8;
        font-size: 14px;
        color: #3a3a3a;
        transition: background-color 0.2s;
    }

    .mc_form-collect .form-content .sub-form .form-item .radio.checked {
        border-color: #c42624;
        background-color: #c42624;
        color: #ffffff;
    }

    .mc_form-collect .form-content .sub-form .form-item .input,
    .mc_form-collect .form-content .sub-form .form-item .file {
        border-radius: 6px;
        border: 1px solid #e8e8e8;
        background: #fff;
        width: 100%;
        height: 48px;
        padding: 0 24px;
        transition: border-color 0.3s;
    }

    .mc_form-collect .form-content .sub-form .form-item .file {
        width: 100px;
        height: 100px;
        padding: 0;
        background: #f8f9fc;
        cursor: pointer;
    }

    .mc_form-collect .form-content .sub-form .form-item .file:before {
        content: '';
        position: absolute;
        width: 100%;
        height: 4px;
        bottom: 0;
        left: 0;
        background-color: #c42624;
        transform: translateX(var(--translate-x));
        transition: transform var(--duration, 0.3s);
    }

    .mc_form-collect .form-content .sub-form .form-item .file ~ .tip {
        padding-top: 12px;
        padding-bottom: 0;
    }

    .mc_form-collect .form-content .sub-form .form-item .file .svg-icon {
        width: 36px;
        height: 36px;
    }

    .mc_form-collect .form-content .sub-form .form-item .file .u-file,
    .mc_form-collect .form-content .sub-form .form-item .file .upload-image {
        position: absolute;
        top: 0;
        left: 0;
        display: none;
    }

    .mc_form-collect .form-content .sub-form .form-item .file .upload-image {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .mc_form-collect .form-content .sub-form .form-item .textarea {
        height: 80px;
    }

    .mc_form-collect .form-content .sub-form .form-item .textarea .text-num {
        font-size: 14px;
        position: absolute;
        right: 9px;
        bottom: 3px;
        color: #afb1b4;
    }

    .mc_form-collect .form-content .sub-form .form-item .textarea .u-textarea {
        padding: 12px 0;
        height: 100%;
        line-height: 1.2;
        resize: none;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap {
        position: relative;
        padding-right: 18px;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .arrow {
        width: 24px;
        transition: transform 0.3s;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .arrow svg {
        width: 70%;
        height: 70%;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap.on .arrow {
        transform: rotate(180deg);
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap.on .drop-list {
        display: block;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .drop-list {
        width: 100%;
        left: 0;
        top: calc(100% + 4px);
        position: absolute;
        z-index: 9;
        border-radius: 6px;
        border: 1px solid #e8e8e8;
        background: #fff;
        box-shadow: 2px 4px 20px 0 rgba(82, 52, 178, 0.1);
        overflow: hidden;
        display: none;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .scroll-view {
        max-height: 240px;
        padding: 8px;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .scroll-view .item {
        line-height: 40px;
        font-size: 14px;
        box-sizing: border-box;
        padding: 0 12px;
        color: #1a1a1a;
        cursor: pointer;
        transition: background 0.2s;
        border-radius: 4px;
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .scroll-view .item:hover {
        background: rgba(217, 217, 217, 0.2);
    }

    .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .scroll-view .item.checked {
        background: rgba(217, 217, 217, 0.2);
        color: #c42624;
    }

    .mc_form-collect .form-content .sub-form .form-item .select-text {
        cursor: pointer;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .mc_form-collect .form-content .sub-form .form-item .u-input,
    .mc_form-collect .form-content .sub-form .form-item .u-textarea,
    .mc_form-collect .form-content .sub-form .form-item .select-text {
        line-height: 42px;
        border: none;
        outline: none;
        background: none;
        flex: 1;
        width: 100%;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.8);
        box-sizing: border-box;
        color: #181623;
    }

    .mc_form-collect .form-content .sub-form .form-item .u-input:-webkit-autofill,
    .mc_form-collect .form-content .sub-form .form-item .u-textarea:-webkit-autofill,
    .mc_form-collect .form-content .sub-form .form-item .select-text:-webkit-autofill {
        transition: background-color 5000s ease-in-out 0s;
        -webkit-box-shadow: 0 0 0 1000px transparent inset !important;
    }

    .mc_form-collect .form-content .sub-form .form-item .u-input:focus,
    .mc_form-collect .form-content .sub-form .form-item .u-textarea:focus,
    .mc_form-collect .form-content .sub-form .form-item .select-text:focus {
        outline: none;
        border: none;
        box-shadow: 0 0 0 2px transparent;
    }

    .mc_form-collect .form-content .sub-form .form-item .u-input::placeholder, .mc_form-collect .form-content .sub-form .form-item .u-input.placeholder,
    .mc_form-collect .form-content .sub-form .form-item .u-textarea::placeholder,
    .mc_form-collect .form-content .sub-form .form-item .u-textarea.placeholder,
    .mc_form-collect .form-content .sub-form .form-item .select-text::placeholder,
    .mc_form-collect .form-content .sub-form .form-item .select-text.placeholder {
        color: #cccccc;
    }

    .mc_form-collect .form-content .submit-success {
        padding-top: 30px;
        display: none;
        color: #181623;
        text-align: center;
        font-size: 16px;
        font-weight: 700;
    }

    .mc_form-collect .form-content .submit-success.show {
        display: flex;
    }

    .mc_form-collect .form-content .submit-success .svg-icon {
        width: 16px;
        height: 16px;
        margin-right: 5px;
    }

    .mc_form-collect .form-content .form-submit {
        padding: 30px 0 20px;
    }

    .mc_form-collect .form-content .form-submit .submit {
        min-width: 400px;
        box-sizing: border-box;
        height: 44px;
        padding: 0 24px;
        border-radius: 44px;
        background: #c42624;
        color: #ffffff;
        cursor: pointer;
        font-size: 15px;
        font-weight: 700;
    }

    .mc_form-collect .form-content .form-submit .submit.disabled {
        opacity: 0.5 !important;
        cursor: not-allowed;
    }

    .mc_form-collect .form-content .form-submit .submit:hover {
        opacity: 0.8;
    }

    .mc_form-collect .form-content .privacy-info {
        justify-content: center;
        line-height: 1.2;
        cursor: pointer;
    }

    .mc_form-collect .form-content .privacy-info.checked .privacy-checkbox {
        background-color: #c42624;
        border-color: #c42624;
    }

    .mc_form-collect .form-content .privacy-info.checked .privacy-checkbox .svg-icon {
        opacity: 1;
    }

    .mc_form-collect .form-content .privacy-info .privacy-checkbox {
        width: 16px;
        height: 16px;
        min-width: 16px;
        border-radius: 4px;
        box-sizing: border-box;
        border: 1.5px solid #181623;
        transition: background-color 0.3s;
    }

    .mc_form-collect .form-content .privacy-info .privacy-checkbox .svg-icon {
        width: 10px;
        height: 10px;
        opacity: 0;
    }

    .mc_form-collect .form-content .privacy-info .text {
        padding-left: 7px;
        font-size: 14px;
        color: #181623;
        font-weight: 400;
        word-break: break-all;
        text-align: left;
    }

    .mc_form-collect .form-content .privacy-info .text a {
        text-decoration: underline;
        color: #181623;
    }

    .mc_form-collect .form-content .privacy-info .text a:hover {
        color: #c42624;
    }

    @media screen and (max-width: 1023px) {
        .mc_form-collect {
            padding: 2.75rem 0;
        }

        .mc_form-collect .title {
            font-size: 1.5rem;
        }

        .mc_form-collect .form-content .form-head {
            font-size: 1rem;
            padding: 1.25rem 0;
        }

        .mc_form-collect .form-content .sub-form {
            margin-top: 1.5rem;
            padding: 1rem 1rem 2.25rem;
            border-radius: 0;
        }

        .mc_form-collect .form-content .sub-form .form-body {
            width: 100%;
            color: #181623;
            flex-wrap: wrap;
        }

        .mc_form-collect .form-content .sub-form .form-item {
            padding-top: 2rem;
            width: 100%;
        }

        .mc_form-collect .form-content .sub-form .form-item .name {
            padding-bottom: 0.5rem;
        }

        .mc_form-collect .form-content .sub-form .form-item .radio-group {
            justify-content: space-between;
            gap: 0.75rem 0;
        }

        .mc_form-collect .form-content .sub-form .form-item .radio {
            padding: 0;
            width: calc(50% - 8px);
        }

        .mc_form-collect .form-content .sub-form .form-item .input {
            padding: 0 1.125rem;
        }

        .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap {
            padding-right: 0.75rem;
        }

        .mc_form-collect .form-content .sub-form .form-item .dropdown-wrap .drop-list {
            border-radius: 0.375rem;
        }

        .mc_form-collect .form-content .form-submit {
            padding: 1.875rem 0 1.25rem;
        }

        .mc_form-collect .form-content .form-submit .submit {
            width: 80%;
            min-width: auto;
        }

        .mc_form-collect .form-content .privacy-info .privacy-checkbox {
            width: 14px;
            height: 14px;
            min-width: 14px;
        }

        .mc_form-collect .form-content .privacy-info .text {
            font-size: 12px;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_form-collect section--page">
    {%- if ss.show_title -%}
        <div class="title" style="color: {{ ss.title_color }};">{{ ss.title }}</div>
    {%- endif -%}
    <div class="form-content" id="{{ section.id }}-form">
        {%- liquid
            assign menus = section.blocks | where: 'type', 'group'
            assign sorts = ''
        -%}
        {%- for menu in menus -%}
            {%- assign ms = menu.settings -%}
            <div class="sub-form">
                <div class="form-head">{{ ms.title }}</div>
                {%- if ms.tip != blank -%}
                    <div class="tip">{{ ms.tip }}</div>
                {%- endif -%}
                <div class="form-body flex-between-top">
                    {%- for block in section.blocks -%}
                        {%- liquid
                            assign type = block.type
                            assign bs = block.settings
                        -%}
                        {%- if ms.title == bs.group_name and type != 'group' -%}
                            {%- liquid
                                assign field = bs.field | handleize | replace: '-', '_'
                                assign sorts = sorts | append: field | append: ','
                            -%}
                            <div class="form-item{% if bs.size_fill %} fill{% endif %}">
                                <div class="name">{{ bs.title }}{%- if bs.required -%}<sup>*</sup>{%- endif -%}</div>
                                {%- if bs.tip != blank and type != 'file' -%}
                                    <div class="tip">{{ bs.tip }}</div>
                                {%- endif -%}
                                {%- case type -%}
                                    {%- when 'radio' -%}
                                        <div class="radio-group flex-left">
                                            {%- assign values = bs.values | newline_to_br | split: '<br />' -%}
                                            {%- for value in values -%}
                                                <span
                                                    node-name="radio"
                                                    data-proxy="radio"
                                                    data-field="{{ field }}"
                                                    class="radio{% if forloop.first %} checked{% endif %} flex-center">{{ value | strip }}</span>
                                            {%- endfor -%}
                                        </div>
                                    {%- when 'input' -%}
                                        {%- if bs.type == 'textarea' -%}
                                            <label class="input textarea relative flex-left">
                                            <textarea
                                                maxlength="{{ bs.limit }}"
                                                node-name="textarea"
                                                name="{{ field }}"
                                                {% if bs.required %}required{% endif %}
                                                placeholder="{{ bs.placeholder }}"
                                                class="u-textarea"></textarea>
                                                <span class="text-num"><span node-name="number">0</span>/{{ bs.limit }}</span>
                                            </label>
                                        {%- else -%}
                                            <label class="input flex-left">
                                                <input
                                                    node-name="input"
                                                    {% if bs.required %}required{% endif %}
                                                    maxlength="{{ bs.limit }}"
                                                    name="{{ field }}"
                                                    placeholder="{{ bs.placeholder }}"
                                                    type="{{ bs.type }}"
                                                    class="u-input"/>
                                            </label>
                                        {%- endif -%}
                                    {%- when 'select' -%}
                                        <div
                                            class="input dropdown-wrap flex-left"
                                            node-name="select"
                                            {% if bs.required %}required{% endif %}
                                            data-type="{{ bs.type }}"
                                            data-field="{{ field }}"
                                            data-proxy="select">
                                            <div node-name="{{ field }}"
                                                 data-placeholder="{{ bs.placeholder }}"
                                                 class="select-text placeholder">{{ bs.placeholder }}</div>
                                            <div class="arrow flex-center">
                                                <svg viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg"
                                                     width="24" height="24">
                                                    <path
                                                        d="M472.064 751.552 72.832 352.32c-22.08-22.08-22.08-57.792 0-79.872 22.016-22.016 57.792-22.08 79.872 0L512 631.744l359.296-359.296c22.016-22.016 57.792-22.08 79.872 0 22.08 22.08 22.016 57.792 0 79.872l-399.232 399.232C529.856 773.568 494.144 773.568 472.064 751.552z"
                                                        fill="#9F9F9F"
                                                    ></path>
                                                </svg>
                                            </div>
                                            <div class="drop-list">
                                                <scroll-area>
                                                    <ul class="scroll-view" node-name="{{ field }}_list">
                                                        {%- if bs.type == 'select' -%}
                                                            {%- assign values = bs.values | newline_to_br | split: '<br />' -%}
                                                            {%- for value in values -%}
                                                                <li
                                                                    data-proxy="option"
                                                                    node-name="option"
                                                                    data-field="{{ field }}"
                                                                    class="item">{{ value | strip }}</li>
                                                            {%- endfor -%}
                                                        {%- endif -%}
                                                    </ul>
                                                </scroll-area>
                                            </div>
                                        </div>
                                    {%- when 'file' -%}
                                        <label
                                            style="--translate-x: -100%; --duration: 0ms"
                                            class="file relative overflow-hidden flex-center">
                                            <input
                                                node-name="file"
                                                class="u-file"
                                                {% if bs.required %}required{% endif %}
                                                name="{{ bs.field | handleize | replace: '-', '_' }}"
                                                type="file"
                                                accept="image/*"/>
                                            <svg class="svg-icon" viewBox="0 0 1024 1024"
                                                 xmlns="http://www.w3.org/2000/svg" width="48" height="48">
                                                <path
                                                    d="M810.666667 938.666667H213.333333c-72.533333 0-128-55.466667-128-128v-170.666667c0-25.6 17.066667-42.666667 42.666667-42.666667s42.666667 17.066667 42.666667 42.666667v170.666667c0 25.6 17.066667 42.666667 42.666666 42.666666h597.333334c25.6 0 42.666667-17.066667 42.666666-42.666666v-170.666667c0-25.6 17.066667-42.666667 42.666667-42.666667s42.666667 17.066667 42.666667 42.666667v170.666667c0 72.533333-55.466667 128-128 128zM725.333333 384c-12.8 0-21.333333-4.266667-29.866666-12.8L512 187.733333 328.533333 371.2c-17.066667 17.066667-42.666667 17.066667-59.733333 0s-17.066667-42.666667 0-59.733333l213.333333-213.333334c17.066667-17.066667 42.666667-17.066667 59.733334 0l213.333333 213.333334c17.066667 17.066667 17.066667 42.666667 0 59.733333-8.533333 8.533333-17.066667 12.8-29.866667 12.8z"></path>
                                                <path
                                                    d="M512 682.666667c-25.6 0-42.666667-17.066667-42.666667-42.666667V128c0-25.6 17.066667-42.666667 42.666667-42.666667s42.666667 17.066667 42.666667 42.666667v512c0 25.6-17.066667 42.666667-42.666667 42.666667z"></path>
                                            </svg>
                                        </label>
                                        {%- if bs.tip != blank -%}
                                            <div class="tip">{{ bs.tip }}</div>
                                        {%- endif -%}
                                {%- endcase -%}
                                {%- if bs.required -%}
                                    <div class="required">{{ bs.required_text }}</div>
                                {%- endif -%}
                            </div>
                        {%- endif -%}
                    {%- endfor -%}
                </div>
            </div>
        {%- endfor -%}
        <div class="submit-success flex-center" node-name="success">
            <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14"
                 fill="none">
                <rect x="1.5" y="1.5" width="11" height="11" rx="5.5" fill="#79E85C" stroke="#61D245"/>
                <path d="M10.1213 5.62132L6.58579 9.15685L4.46447 7.03553" stroke="white" stroke-linecap="round"
                      stroke-linejoin="round"/>
            </svg>
            {{ ss.success }}
        </div>
        <div class="form-submit flex-center">
            <button
                node-name="submit"
                is="custom-button"
                class="submit relative flex-center{% if ss.show_privacy and ss.show_privacy == false %} disabled{% endif %}"
                style="color: {{ ss.btn_color }}; background-color: {{ ss.btn_bg_color }};">{{ ss.btn }}</button>
        </div>
        {%- if ss.show_privacy -%}
            <div node-name="privacy" class="privacy-info{% if ss.privacy_checked %} checked{% endif %} flex-top">
                <div class="privacy-checkbox flex-center">
                    <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" width="10.707" height="7.511"
                         viewBox="0 0 10.707 7.511">
                        <path d="M-11467.566,874.83l3.55,3.55,6.45-6.451" transform="translate(11467.92 -871.575)"
                              fill="none" stroke="#fff" stroke-width="1"></path>
                    </svg>
                </div>
                <div class="text">
                    {{ ss.privacy_text }}
                </div>
            </div>
        {%- endif -%}
    </div>
</div>
<script>
    (function () {
        const node = document.getElementById('{{ section.id }}-form');
        const {nodeList} = $heybike.tabSwitch({
            root: node,
            type: 'radio',
            selector: 'checked',
            group: 'field'
        });
        nodeList.option = [].concat(nodeList.option || []);
        {%- assign selects = section.blocks | where: 'type', 'select' -%}
        const options = {
            {%- for block in selects -%}
            {%- assign bs = block.settings -%}
            {%- if bs.type == 'cascade' -%}
            "{{ bs.parent_field | handleize | replace: '-', '_' }}": {
                field: "{{ bs.field | handleize | replace: '-', '_' }}",
                {%- assign values = bs.values | newline_to_br | split: '<br />' -%}
                {%- for value in values -%}
                {%- liquid
                    assign res = value | split: '='
                    assign list = res | last | split: '|'
                -%}
                "{{ res[0] | strip }}": {{ list | json }}{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
            }{% unless forloop.last %},{% endunless %}
            {%- endif -%}
            {%- endfor -%}
        };

        let formData = {};
        const radios = [].concat(nodeList.radio || []);
        const inputs = [].concat(nodeList.input || []);
        const numbers = [].concat(nodeList.number || []);
        const textareas = [].concat(nodeList.textarea || []);
        const files = [].concat(nodeList.file || []);
        const selects = [].concat(nodeList.select || []);
        const dropOpen = $heybike.ref(false);
        $heybike.watch(dropOpen, n => {
            if (!n) {
                selects.forEach(el => el.classList.remove('on'));
            }
        });

        const {trigger} = $heybike.proxy(node, 'select', ({elem, event}) => {
            elem.classList.toggle('on');
            dropOpen.value = elem.classList.contains('on');
            dropOpen.value && elem.closest('.form-item')?.classList.remove('error');
            event.stopPropagation?.();
        });

        const getOptionHTML = (list, field) => {
            return list.map(v => `<li data-proxy="option" node-name="option" data-field="${field}" class="item">${v}</li>`).join('');
        }

        const onOptionCb = ({elem, self}) => {
            try {
                const field = elem.dataset.field;
                if (self) {
                    return trigger(nodeList[field].parentNode);
                }
                const value = elem.innerHTML;
                formData[field] = value;
                const tn = nodeList[field];
                tn.classList.remove('placeholder');
                tn.innerHTML = value;
                trigger(tn.parentNode);
                const option = options[field];
                if (option) {
                    const cf = option.field;
                    formData[cf] = undefined;
                    const sub = nodeList[cf];
                    sub.innerHTML = sub.dataset.placeholder;
                    sub.classList.add('placeholder');
                    nodeList[`${cf}_list`].innerHTML = getOptionHTML(option[value] || [], cf);
                    nodeList.option = nodeList.option.filter(v => v.dataset.field !== cf);
                    nodeList.option.push(...$heybike.getNodeList(nodeList[`${cf}_list`]).option);
                }
            } catch (e) {
                console.error(e);
            }
        }

        $heybike.tabSwitch({
            root: node,
            type: 'option',
            selector: 'checked',
            group: 'field',
            cb: onOptionCb,
            nodeList
        });

        $heybike.on('click', (e) => {
            if (!e.target.closest('.drop-list')) {
                dropOpen.value = false;
            }
        });

        textareas.forEach((elem, index) => {
            elem.addEventListener('input', (e) => {
                const value = e.target.value;
                numbers[index].innerText = value.length;
            });
        });

        inputs.concat(textareas).forEach(elem => {
            elem.addEventListener('focus', () => elem.closest('.form-item')?.classList.remove('error'));
        });

        const startProgress = (elem) => {
            let percent = 0;
            let _cut = 2;
            elem.style.setProperty('--duration', `0ms`);
            const increase = num => {
                return Math.round(Math.min(95, percent + num));
            };

            let _timer = setInterval(() => {
                percent = increase(_cut * Math.random());
                if (percent > 50) {
                    _cut = 1;
                } else if (percent > 70) {
                    _cut = 0.5;
                } else if (percent > 85) {
                    _cut = 0.1;
                }
                elem.style.setProperty('--translate-x', `${percent - 100}%`);
            }, 100);

            return () => {
                percent = 100;
                elem.style.setProperty('--duration', `300ms`);
                elem.style.setProperty('--translate-x', `${percent - 100}%`);
                clearInterval(_timer);
            }
        };

        // 开始上传
        const onUploadFile = async (elem, file) => {
            const box = elem.parentNode;
            const reader = new FileReader();
            let image = null;
            reader.onload = function (result) {
                image = box.querySelector('.upload-image');
                if (!image) {
                    image = document.createElement('img');
                    image.loading = 'lazy';
                    image.classList.add('upload-image');
                    box.appendChild(image);
                }
                image.src = result?.target?.result;
            };
            reader.readAsDataURL(file);

            const finish = startProgress(elem.parentNode);
            const body = new FormData();
            body.append('file', file);
            const response = await fetch('https://img.yozmasport.com/api/v1/upload', {
                method: 'POST',
                headers: {
                    "Accept": "application/json"
                },
                body: body
            });

            elem.closest('.form-item')?.classList.remove('error');
            if (response.ok) {
                const data = await (await response.json());
                formData[elem.name] = data.data.links.url;
            }else {
                formData[elem.name] = '';
                image && box.removeChild(image);
                box.style.setProperty('--translate-x', `-100%`);
                alert(`Upload fail - HTTP ${response.status}`);
            }

            finish();
        }

        files.forEach(elem => {
            elem.addEventListener('change', (ev) => {
                const file = ev.target.files?.[0];
                if (!file) {
                    return false;
                }
                if (file.size > 5 * 1024 * 1024) {
                    return alert('The size of the image cannot exceed 5 megabytes.');
                }
                onUploadFile(elem, file);
            });
        })

        nodeList.privacy?.addEventListener('click', (ev) => {
            if (ev.target.tagName.toLocaleLowerCase() === 'a') {
                return false;
            }
            ev.preventDefault();
            ev.stopPropagation();
            nodeList.privacy.classList.toggle('checked');
            nodeList.privacy.classList.remove('error');
            nodeList.submit.classList.toggle('disabled', !nodeList.privacy.classList.contains('checked'));
        });

        const verifyEmail = (val) => {
            const reg1 = /@([a-zA-Z0-9_-])+(\.[a-zA-Z0-9_-])+/;//防止输入过长的时候，卡死
            const reg2 = /^([a-zA-Z0-9_-]+[_|\_|\.]?)+@([a-zA-Z0-9_-])+(\.[a-zA-Z0-9_-])+/;
            if (reg1.test(val)) {
                return reg2.test(val);
            }
            return false;
        }

        const onClearFormData = () => {
            formData = {};
            inputs.concat(textareas).forEach(input => {
                input.value = '';
            });
            selects.forEach(select => {
                const field = select.dataset.field;
                const cf = nodeList[field];
                cf.classList.add('placeholder');
                cf.innerHTML = cf.dataset.placeholder;
            });
            [].concat(nodeList.option).forEach(elem => elem.classList.remove('checked'));
            files.forEach(file => {
                const box = file.parentNode;
                box.style.setProperty('--translate-x', `-100%`);
                const image = box.querySelector('.upload-image');
                image && box.removeChild(image);
            });
        }

        const scrollTo = (to, elem) => {
            to && window.scrollTo({
                top: $heybike.getOffset(elem.parentNode).top - 100,
                behavior: "smooth"
            })
        }

        nodeList.submit.addEventListener('click', async () => {
            if (nodeList.submit.classList.contains('disabled')) {
                return false;
            }
            let isVerify = true;
            radios.forEach(radio => {
                if (radio.classList.contains('checked')) {
                    const field = radio.dataset.field;
                    formData[field] = radio.innerText;
                }
            });
            inputs.concat(textareas).forEach(input => {
                const field = input.name;
                const value = input.value.trim();
                formData[field] = value;
                if (input.hasAttribute('required')) {
                    if (!value || (input.type === 'email' && !verifyEmail(value))) {
                        input.closest('.form-item')?.classList.add('error');
                        scrollTo(isVerify, input);
                        isVerify = false;
                    }
                }
            });
            selects.forEach(select => {
                const field = select.dataset.field;
                if (select.hasAttribute('required')) {
                    if (!formData[field]) {
                        select.closest('.form-item')?.classList.add('error');
                        scrollTo(isVerify, select);
                        isVerify = false;
                    }
                }
            });
            files.forEach(file => {
                if (file.hasAttribute('required')) {
                    if (!formData[file.name]) {
                        file.closest('.form-item')?.classList.add('error');
                        scrollTo(isVerify, file);
                        isVerify = false;
                    }
                }
            });

            if (isVerify) {
                nodeList.submit.setAttribute('aria-disabled', 'true');
                nodeList.submit.setAttribute('aria-busy', 'true');
                const url = 'https://script.google.com/macros/s/{{ ss.token }}/exec';
                const data = new FormData();
                data.append('__form_sorts', '{{ sorts | remove_last: ',' }}')
                Object.keys(formData).forEach(key => {
                    data.append(key, formData[key]);
                });
                const response = await fetch(url, {
                    method: 'POST',
                    body: data
                });
                if (response.ok) {
                    onClearFormData();
                    nodeList.success.classList.add('show');
                    setTimeout(() => {
                        nodeList.success.classList.remove('show');
                    }, 3000);
                } else {
                    alert(`{{ ss.fail }} - HTTP ${response.status}`);
                }
                nodeList.submit.removeAttribute('aria-disabled');
                nodeList.submit.removeAttribute('aria-busy');
            }
        });
    })();
</script>
