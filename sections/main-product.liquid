{%- render 'section-spacing-collapsing' -%}
{%- assign ss = section.settings -%}

<style>
    #shopify-section-{{ section.id }} {
        --product-grid: auto / minmax(0, 1fr);
        --product-gallery-media-list-grid: auto / auto-flow {% if section.settings.mobile_carousel_control == 'free_scroll' %}{% if section.settings.mobile_media_size == 'expanded' %} 84vw {% else %} 73vw {% endif %}{% else %} 100%{% endif %};
        --product-gallery-media-list-gap: {% if section.settings.mobile_media_size == 'expanded' %}var(--spacing-0-5){% else %}var(--grid-gutter){% endif %};
        background: {{ ss.background }};
    }

    #nextop-chat {
        bottom: 80px !important;
    }

    .price-list .save-badge {
        padding: 5px 12px 4px;
        color: #FFF;
        font-size: 14px;
        background-color: #D30000;
        border-radius: 50px;
        transform: translateY(-2px);
    }

    .product-gallery [data-hidden] {
        display: none;
    }

    #shopify-section-{{ section.id }} .product-info > * + * {
        --product-info-block-spacing: 0 !important;
    }

    .product-info .product-info__block-item {
        padding: var(--desktop-padding);
    }

    @media screen and (max-width: 999px) {
        #shopify-section-{{ section.id }} {
            --section-spacing-block-start: {% if section.settings.mobile_media_size == 'expanded' %}0 px{% else %}var(--container-gutter){% endif %};
        }

        .product-info .product-info__block-item {
            padding: var(--mobile-padding);
        }

         .price-list .save-badge {
            padding: 4px 10px 3px;
            font-size: 10px;
        }
    }

    @media screen and (min-width: 1000px) {
        #shopify-section-{{ section.id }} {
        {%- assign media_ratio = section.settings.desktop_media_width | divided_by: 50.0 -%} --product-grid: auto / minmax(0, {{ media_ratio }}fr) minmax(0, {{ 2.0 | minus: media_ratio }}fr);
            --product-gallery-media-list-grid: {% if section.settings.desktop_media_layout contains 'grid' %}auto-flow dense / repeat({% if section.settings.desktop_media_layout == 'grid_one' %}1{% else %}2{% endif %}, minmax(0, 1fr)){% else %}auto / auto-flow 100%{% endif %};
            --product-gallery-media-list-gap: calc(var(--grid-gutter) / 2);
        }

    {%- if section.settings.desktop_media_layout == 'grid_highlight' -%}
        #shopify-section-{{ section.id }} .product-gallery__media-list > :not([hidden]) {
            grid-column: span 2;
        }

        #shopify-section-{{ section.id }} .product-gallery__media-list > :not([hidden]) ~ *:not(.product-gallery__media--expand) {
            grid-column: span 1;
        }

    {%- endif -%}
    }

    @media screen and (min-width: 1400px) {
        #shopify-section-{{ section.id }} {
            --product-gallery-media-list-gap: var(--grid-gutter);
        }
    }

    .product-info__title-wrap .product-info__title {
        flex: 1;
        padding-right: 30px;
    }

    .product-info__title-wrap .image-button {
        --button-width: 80px;
        --button-height: 37px;
        --button-size: 1rem;
        --button-color: #FFFFFF;
    }

    .product-info__image-card .image {
        width: 100%;
        height: auto;
        object-fit: contain;
        border-radius: 12px;
    }

    klarna-placement::part(osm-badge) {
        width: 52px;
        height: 36px;
        border-radius: 6px;
        background-color: #FFA8CD;
    }

    klarna-placement::part(osm-container) {
        border: 0 none;
        padding-left: 0;
        padding-right: 0;
    }

    klarna-placement::part(osm-message) {
        font-size: 18px;
        font-style: italic;
        font-weight: 900;
        font-family: Roboto, sans-serif;
        letter-spacing: -0.36px;
    }

    klarna-placement::part(osm-cta) {
        color: #0BF003;
        display: block;
    }

    model-media {
        width: 100%;
        height: 100%;
    }

    .product-gallery__media .shopify-model-viewer-ui model-viewer.shopify-model-viewer-ui__disabled {
        pointer-events: visible;
    }

    .product-gallery__buttons.not-slide-button:before,
    .product-gallery__buttons.not-slide-button:after{
        display: none;
    }
    .product-gallery__buttons:hover:before,
    .product-gallery__buttons:hover:after {
        opacity: 1;
    }

    .product-gallery__other-list.active ~ .media-other-button,
    .media-other-button ~ .product-gallery__other-list.active ~ .media-other-button{
        display: flex;
    }

    .product-gallery__other-list:not(.active) ~ .media-other-button {
        display: none;
    }

    .product-gallery__media-list-wrapper:has(.product-gallery__other-list.active):hover .active ~ .media-other-button {
        opacity: 1;
    }

    .media-other-button {
        width: 50px;
        top: 50%;
        transform: translateY(-50%);
        left: 0;
        display: none;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .media-button-next {
        left: auto;
        right: 0;
    }

    .product-gallery__buttons:before,
    .product-gallery__buttons:after {
        content: '';
        width: 26px;
        height: 26px;
        --button-image: url('https://cdn.shopify.com/s/files/1/0682/5646/5034/files/product-gallery-slide-btn.png?v=1770280623');
        background: var(--button-image) no-repeat;
        background-size: contain;
        position: absolute;
        top: 50%;
        margin-top: -13px;
        z-index: 1;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .product-gallery__buttons.is-first:before,
    .product-gallery__buttons.is-last:after {
        --button-image: url("https://cdn.shopify.com/s/files/1/0682/5646/5034/files/product-gallery-slide-btn-disabled.png?v=1770280565");
        cursor: not-allowed;
    }

    .product-gallery__buttons:before {
        left: 18px;
        transform: rotate(180deg);
    }

    .product-gallery__buttons:after {
        right: 18px;
    }

    .thumbnail-slide-button {
        transition: transform 0.3s;
        cursor: pointer;
    }

    .thumbnail-slide-button:hover {
        transform: scale(1.05);
    }

    .thumbnail-slide-button .image {
        width: 26px;
        height: 26px;
        object-fit: contain;
    }

    .thumbnail-slide-button.disabled {
        cursor: not-allowed;
        transform: scale(1) !important;
        opacity: 0.5;
    }

    .product-info__title {
        font-size: 2rem;
        line-height: 1.2;
        font-weight: 900;
        font-style: italic;
    }

    .review--score .review-text {
        font-size: 12px;
        color: #999999;
        padding-left: 6px;
        line-height: 1.2;
        transform: translateY(3px);
    }

    .review--score .score-items {
        --score-size: 16px;
    }

    .product-info__price .price-list {
        gap: 8px;
    }

    .product-info__price sale-price {
        font-size: 24px;
        font-style: italic;
        font-weight: 900;
        letter-spacing: -0.64px;
        color: #000000;
    }

    .product-quick-add .price-list {
        padding-right: 20px;
    }

    .product-quick-add .discount-tag {
        padding: 3px 6px 2px;
        background-color: #D30000;
        border-radius: 2px;
        font-size: 12px;
        color: #FFFFFF;
        position: absolute;
        text-decoration: none;
        top: -18px;
        transform: scale(0.85);
    }

    .product-info__price compare-at-price {
        font-size: 1rem;
        font-weight: 300;
        color: #999999;
    }

    .product-quick-add compare-at-price {
        font-size: 12px;
    }


    @media screen and (max-width: 999px) {
        .product-info__title {
            font-size: 1.25rem;
        }

        .media-other-button {
            display: none !important;
        }

        .product-quick-add {
            padding: 12px 12px 7px;
        }

        .product-quick-add .product-info__price {
            flex-direction: column;
        }

        .product-quick-add .shopify-product-form {
            width: 100%;
        }

        .product-quick-add .shopify-product-form .v-stack {
            max-width: 100%;
        }

        .product-quick-add .buy-buttons {
            gap: 0 4px;
        }

        .product-quick-add .button {
            flex: 1;
            height: 28px;
            padding: 0 !important;
            font-size: 12px;
        }

        .product-quick-add .button > div {
            transform: translateY(1px);
        }

        .product-quick-add .v-stack {
            gap: 0;
            max-width: 70%;
            padding-bottom: 5px;
        }

        .product-quick-add .truncate-text {
            font-size: 10px;
            line-height: 1.1;
        }

        .product-quick-add p {
            font-size: 8px;
            line-height: 1.1;
        }

        .product-quick-add .discount-tag {
            padding: 2px 4px 1px;
            font-size: 8px;
            border-radius: 2px;
            top: -12px;
            transform: scale(1);
        }

        .product-quick-add .price-list {
            position: absolute;
            right: 12px;
            bottom: 40px;
            padding-right: 0;
        }

        .product-quick-add sale-price {
            font-size: 12px !important;
            transform: translateY(-5px);
        }

        .product-quick-add compare-at-price {
            font-size: 8px !important;
        }

        .product-info__title-wrap .image-button {
            --button-width: 49px;
            --button-height: 24px;
            --button-size: 10px;
        }

        .review--score .review-text {
            font-size: 10px;
            padding-left: 4px;
            transform: translateY(1px);
        }

        .review--score .score-items {
            --score-size: 12px;
        }

        .product-gallery__buttons:before,
        .product-gallery__buttons:after {
            width: 15px;
            height: 15px;
            margin-top: -7.5px;
            opacity: 0 !important;
        }

        .product-gallery__buttons:before {
            left: -10px;
        }

        .product-gallery__buttons:after {
            right: -10px;
        }

        .thumbnail-slide-button .image {
            width: 15px;
            height: 15px;
        }


        .product-info__price sale-price {
            font-size: 1.25rem;
        }

        .product-info__price compare-at-price {
            font-size: 10px;
        }

        klarna-placement::part(osm-badge) {
            width: 32px;
            height: 22px;
            border-radius: 4px;
        }

        klarna-placement::part(osm-message) {
            font-size: 12px;
            letter-spacing: -0.436px;
            line-height: 1;
            margin-left: -6px;
        }

        klarna-placement::part(osm-cta) {
            font-size: 11px;
            line-height: 1.2;
        }

        /*.shopify-model-viewer-ui .shopify-model-viewer-ui__controls-area {*/
        /*    opacity: 1 !important;*/
        /*    display: flex !important;*/
        /*}*/
    }

    {%- assign content = section.blocks | where: 'type', 'content' | first -%}
    {%- if content != blank -%}
    .product-info__content ul {
        gap: 5px 0;
    }

    .product-info__content ul li {
        list-style: none;
        padding-left: 12px;
        position: relative;
        font-size: 12px;
        line-height: 1.1;
    }

    .product-info__content ul li:before {
        content: '';
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #000000;
        position: absolute;
        left: 3px;
        top: 3px;
    }

    {%- endif -%}
    {%- assign timer = section.blocks | where: 'type', 'countdown_timer' | first -%}
    {%- if timer != blank -%}
    {%- assign ts = timer.settings -%}
    .countdown-timer-wrapper {
        height: 80px;
        padding: 0 20px;
    }

    .countdown-timer-wrapper .backdrop-img {
        top: 0;
        left: 0;
        object-fit: cover;
    }

    .countdown-timer-wrapper .message-info .image {
        width: 24px;
        height: 24px;
        object-fit: contain;
        margin-right: 10px;
    }

    .countdown-timer-wrapper .text {
        color: var(--text-color);
        font-size: 24px;
    }

    .countdown-timer-wrapper .countdown--bar {
        gap: 0 18px;
    }

    .countdown-timer-wrapper .countdown--bar .countdown--item {
        width: 44px;
        height: 44px;
        background: {{ ts.countdown_fill_color }};
        border-radius: 5px;
        flex-direction: column;
        position: relative;
    }

    .countdown-timer-wrapper .countdown--bar .countdown--item:last-of-type:before {
        display: none;
    }

    .countdown-timer-wrapper .countdown--bar .countdown--item:before {
        content: ":";
        font-size: 20px;
        font-weight: 900;
        color: {{ ts.countdown_dot_color }};
        position: absolute;
        right: -12px;
        top: 45%;
        transform: translateY(-50%);
    }

    .countdown-timer-wrapper .countdown--bar .num {
        width: 100%;
        color: {{ ts.countdown_num_color }};
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        box-sizing: border-box;
        line-height: 1.2;
        border: 0 none;
        background: none;
        transform: translateY(3px);
    }

    .countdown-timer-wrapper .countdown--bar .num:disabled {
        opacity: 1;
    }

    .countdown-timer-wrapper .countdown--bar .countdown--item .name {
        font-size: 12px;
        line-height: 1.1;
        transform: scale(0.8) translateY(4px);
        color: {{ ts.countdown_text_color }};
    }

    @media screen and (max-width: 1440px) {
        .countdown-timer-wrapper .text {
            font-size: 20px;
        }
    }

    @media screen and (max-width: 999px) {
        .countdown-timer-wrapper {
            height: 49px;
            padding: 0 12px;
            border-radius: 6px;
        }

        .countdown-timer-wrapper .message-info .image {
            width: 15px;
            height: 15px;
            margin-right: 6px;
        }

        .countdown-timer-wrapper .text {
            font-size: 15px;
        }

        .countdown-timer-wrapper .countdown--bar {
            gap: 0 10px;
        }

        .countdown-timer-wrapper .countdown--bar .countdown--item {
            width: 26px;
            height: 26px;
            border-radius: 3px;
        }

        .countdown-timer-wrapper .countdown--bar .countdown--item:before {
            font-size: 13px;
            right: -7px;
            top: 50%;
        }

        .countdown-timer-wrapper .countdown--bar .num {
            font-size: 12px;
            transform: translateY(1px);
        }

        .countdown-timer-wrapper .countdown--bar .countdown--item .name {
            font-size: 6px;
            transform: translateY(2px);
        }
    }

    {%- endif -%}
    {%- assign bundled_sale = section.blocks | where: 'type', 'bundled_sale' | first -%}
    {%- if bundled_sale != blank -%}
    .bundled_sale .bundle-image {
        width: 100px;
        height: 100px;
    }

    .bundled_sale .scroll-area-view:not(.hidden-bar):before,
    .bundled_sale .scroll-area-view:not(.hidden-bar):after {
        opacity: 0;
        transition: opacity 0.3s;
    }

    .bundled_sale:hover .scroll-area-view:not(.hidden-bar):before,
    .bundled_sale:hover .scroll-area-view:not(.hidden-bar):after {
        opacity: 1;
    }

    .bundled_sale .scroll-view {
        max-height: 484px;
    }

    .bundled_sale .bundle-image img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .bundled_sale .bundle-item {
        border: 1px solid #EFEFEF;
        padding: 5px 22px 5px 28px;
    }

    .bundled_sale .disabled {
        cursor: default;
    }

    .bundled_sale .disabled .checkbox {
        opacity: 1;
    }

    .bundled_sale .bundle-info {
        width: 10vw;
        flex: 1;
        --spacing-4: 1.375rem;
    }

    .bundled_sale .checkbox {
        --spacing-4: 1.375rem;
        margin-right: 10px;
    }

    .bundled_sale .discount-tag {
        padding: 4px 5px 3px;
        color: #FFF;
        font-size: 12px;
        letter-spacing: -0.364px;
        background-color: #D30000;
        border-radius: 2px;
        display: inline-block;
        margin-bottom: 4px;
    }

    .bundled_sale .quantity {
        border-radius: 0;
        height: 22px;
        font-size: 12px;
    }

    .bundled_sale .name,
    .bundled_sale .price {
        font-size: 16px;
    }

    .bundled_sale .original-price,
    .bundled_sale .desc {
        font-size: 12px;
        color: #999;
    }

    .bundled_sale .original-price {
        text-decoration: line-through;
    }

    .bundled_sale .bundle-footer {
        align-items: flex-end;
    }

    @media screen and (max-width: 999px) {
        bundled_sale .scroll-area-view:not(.hidden-bar):before,
        .bundled_sale .scroll-area-view:not(.hidden-bar):after {
            opacity: 1;
        }

        .bundled_sale .scroll-view {
            max-height: 200px;
            gap: 8px;
        }

        .bundled_sale .bundle-image {
            width: 42px;
            height: 42px;
        }

        .bundled_sale .bundle-item {
            padding: 5px 15px 5px 15px;
            gap: 0.5rem;
        }

        .bundled_sale .bundle-info {
            width: 10vw;
            flex: 1;
            --spacing-4: 1.375rem;
        }

        .bundled_sale .checkbox {
            --spacing-4: 0.9rem;
            margin-right: 5px;
            transform: translateY(-2px);
        }

        .bundled_sale .discount-tag {
            padding: 2px 3px 1px;
            font-size: 9px;
            margin-bottom: 2px;
        }

        .bundled_sale .quantity {
            border-radius: 0;
            height: 22px;
            font-size: 12px;
        }

        .bundled_sale .name,
        .bundled_sale .price {
            font-size: 12px;
        }

        .bundled_sale .original-price,
        .bundled_sale .desc {
            font-size: 10px;
            color: #999;
        }
    }

    {%- endif -%}
    .product-info__buy-buttons .buy-buttons {
        display: flex;
        flex-direction: column;
        gap: 10px 0;
        align-items: flex-end;
    }

    .product-info__buy-buttons .button {
        border-radius: 0;
        width: 100%;
        height: 55px;
        padding: 0;
    }

    .product-info__buy-box .button[type="submit"] {
        width: calc(100% - 185px);
    }

    .product-info__buy-box .quantity-selector {
        border-radius: 0;
        --input-height: 55px;
        width: 175px;
    }

    .product-info__buy-box .quantity-selector__input {
        flex: 1;
        font-size: 24px;
    }

    .product-info .accordion-group .product-info__block-item:first-of-type .accordion {
        border-top: none;
    }

    .product-info .accordion__toggle {
        padding: 17px 0;
    }

    .product-info .accordion__toggle .text-with-icon {
        font-size: 14px;
        font-weight: 600;
        gap: 10px;
    }

    @media screen and (max-width: 999px) {
        .product-info__buy-buttons .buy-buttons {
            gap: 6px 0;
        }

        .product-info__buy-buttons .button {
            border-radius: 0;
            width: 100%;
            height: 34px;
            padding: 0;
        }

        .product-info__buy-buttons .button > div {
            transform: translateY(1px);
        }

        .product-info__buy-box .button[type="submit"] {
            width: calc(100% - 112px);
        }

        .product-info__buy-box .quantity-selector__button {
            --spacing-5: 0.96rem;
        }

        .product-info__buy-box .quantity-selector {
            --input-height: 34px;
            width: 106px;
        }

        .product-info__buy-box .quantity-selector__input {
            font-size: 15px;
        }
    }

    .product-info .accordion__toggle .circle-chevron {
        background: none;
        border: 1px solid #EFEFEF;
    }

    .product-info .accordion__toggle .circle-chevron .icon {
        width: 8px;
        height: 8px;
    }

    .product-info .group[aria-expanded="true"] .circle-chevron.group-expanded\:rotate {
        --transform-logical-flip: 0.25;
    }

    {%- assign collapsible_text_icon = section.blocks | where: 'type', 'collapsible_text_icon' | first -%}
    {%- if collapsible_text_icon != blank -%}
    .product-info__accordion-icon .accordion__content {
        flex-wrap: wrap;
         gap: 10px 0;
    }

    .product-info__accordion-icon .accordion__icon {
        width: var(--column-val);
    }

    .product-info__accordion-icon .accordion__icon .image {
        width: 48px;
        aspect-ratio: 1;
        height: auto;
        object-fit: contain;
        margin: 0 auto;
    }

    .product-info__accordion-icon .accordion__icon .info {
        padding-top: 6px;
    }

    .product-info__accordion-icon .accordion__icon .name {
        color: #000000;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.4;
    }

    .product-info__accordion-icon .accordion__icon .desc {
        color: #666666;
        font-size: 12px;
        line-height: 1.4;
    }

    @media screen and (max-width: 999px) {
        .product-info__accordion-icon .accordion__icon {
            width: var(--mb-column-val);
        }

        .product-info__accordion-icon .accordion__icon .image {
            width: 50%;
        }

        .product-info__accordion-icon .accordion__icon .info {
            padding-top: 4px;
        }

        .product-info__accordion-icon .accordion__icon .name {
            font-size: 14px;
            line-height: 1.2;
            padding-top: 4px;
        }

        .product-info__accordion-icon .accordion__icon .desc {
            font-size: 10px;
            line-height: 1.2;
        }
    }

    {%- endif -%}

    .category-selector .selector-inner {
        height: 38px;
        background-color: #F9F9F8;
        padding: 2px;
    }

    .category-selector .selector-item {
        padding: 0 25px;
        height: 100%;
        color: #000000;
        font-size: 18px;
        transition: background-color 0.5s;
        transition-property: background-color, color;
        white-space: nowrap;
    }

    .category-selector .selector-item svg {
      width: 24px;
      height: 24px;
      margin-right: 4px;
      transform: translateY(-1px);
    }

    .category-selector .selector-item.active {
        background-color: #d30000;
        color: #ffffff;
        font-weight: 600;
    }

    .selector-item.active .svg-icon path {
        fill: #FFFFFF;
    }

    .selector-item.active .svg-3d path:nth-child(3) {
        stroke: #D30000;
    }

    .hidden-important {
        display: none !important;
    }

    @media screen and (max-width: 999px) {
        .category-selector .selector-inner {
            height: 28px;
            padding: 2px;
        }

        .category-selector .selector-item {
            padding: 0 12px;
            font-size: 14px;
        }

        .category-selector .selector-item svg {
          width: 18px;
          height: 18px;
          margin-right: 3px;
        }
    }
</style>

{%- capture product_form_id -%}product-form-{{ product.id }}-{{ section.id }}{%- endcapture -%}

<div {% render 'section-properties', tight: true %}>
    <product-rerender id="product-info-{{ product.id }}-{{ section.id }}" observe-form="{{ product_form_id }}"
                      allow-partial-rerender>
        <div class="product">
            {%- if product.media.size > 0 -%}
                {%- render 'product-gallery', enable_specs: ss.enable_specs, product: product, product_form_id: product_form_id -%}
            {%- endif -%}

            {%- render 'product-info',
                product: product,
                update_url: true,
                product_form_id: product_form_id,
                context: 'main_product'
            -%}
        </div>
    </product-rerender>
</div>

{%- assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first -%}

{%- if ss.show_fixed_add_to_cart and product.available and buy_buttons_block != blank -%}
    <product-rerender id="{{ product_form_id }}-sticky-bar" observe-form="{{ product_form_id }}">
        {%- if product.selected_or_first_available_variant.available -%}
            <product-quick-add form="{{ product_form_id }}" class="product-quick-add">
                <div class="product-quick-add__variant {% if image == blank %}no-image{% endif %} tw-grid">
                    <div class="v-stack gap-0.5">
                        {%- assign vendor_block = section.blocks | where: 'type', 'vendor' -%}

                        {%- if vendor_block != blank -%}
                            {%- render 'vendor' with product.vendor, class: 'text-xs' -%}
                        {%- endif -%}

                        <a href="{{ product.url }}"
                           class="tw-text-lg italic fw-900 truncate-text">{{ product.title }}</a>
                        {% if section.settings.fixed_content %}
                            <p class="tw-text-sm">{{ section.settings.fixed_content }}</p>
                        {% endif %}
                    </div>
                    <div class="flex-left product-info__price">
                        {%- render 'price-list',
                            product: product,
                            variant: product.selected_or_first_available_variant,
                            form_id: product_form_id,
                            show_tag: ss.show_fixed_discount_tag,
                            tag_text: ss.fixed_discount_tag
                        -%}
                        {%- render 'buy-buttons',
                            product: product,
                            form_id: product_form_id,
                            show_payment_button: buy_buttons_block.settings.show_payment_button,
                            show_gift_card_recipient: buy_buttons_block.settings.show_gift_card_recipient,
                            atc_button_background: buy_buttons_block.settings.atc_button_background,
                            atc_button_text_color: buy_buttons_block.settings.atc_button_text_color,
                            payment_button_background: buy_buttons_block.settings.payment_button_background,
                            payment_button_text_color: buy_buttons_block.settings.payment_button_text_color,
                            payment_button_text: buy_buttons_block.settings.payment_button_text
                        -%}
                    </div>
                </div>
            </product-quick-add>
        {%- endif -%}
    </product-rerender>
{%- endif -%}

{%- comment -%}
IMPLEMENTATION NOTE: Shopify does not currently allows to render a given section within the context of a given product. However,
when rendering the quick buy popovers, we want to be able to re-use the merchant's choices (such as the selector type). This
is however only possible by rendering the whole product page, and extracting the relevant part. Here, we therefore render the
quick buy information in a template, that will be extracted in JS, but ensure it is not visible in the main product page
{%- endcomment -%}

{%- render 'product-quick-buy', product: product -%}

