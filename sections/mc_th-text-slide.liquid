{%- liquid
    assign ss = section.settings
    assign cid = section.id | split: '__' | last
-%}
<style>
    .mc_th-text-slide {
        background: #000000;
        padding: 60px 0;
    }
    .mc_th-text-slide .slide-content {
        gap: 0 10px;
        align-items: stretch;
    }
    .mc_th-text-slide .slide-desc {
        margin-top: 10px;
        max-width: 1400px;
        background-color: {{ ss.slide_card_bg_color }};
        padding: 28px 32px;
        font-size: 20px;
        color: #666;
    }
    .mc_th-text-slide .slide-desc .desc {
        display: none;
    }
    .mc_th-text-slide .slide-desc .desc.active {
        display: block;
    }
    .mc_th-text-slide .slide-desc > .image {
        width: auto;
        max-height: 290px;
        height: 75%;
        object-fit: contain;
        top: 38px;
        right: 34px;
    }
    .mc_th-text-slide .text-slide-items {
        width: 272px;
        gap: 5px;
        padding: 5px;
        background-color: {{ ss.slide_card_bg_color }};
    }
    .mc_th-text-slide .item {
        padding: 24px 16px 18px;
        min-height: 115px;
        transition: background-color 0.3s;
        color: {{ ss.slide_text_color }};
    }
    .mc_th-text-slide .item:before {
        content: "";
        width: 3px;
        height: 84px;
        background-color: {{ ss.slide_text_color }};
        right: 8px;
        top: 50%;
        margin-top: -42px;
        position: absolute;
        transform: scaleY(0);
        transition: transform 0.3s;
    }
    .mc_th-text-slide .item.active {
        background-color: {{ ss.slide_active_color }};
    }
    .mc_th-text-slide .item.active:before {
        transform: scaleY(1);
    }
    .mc_th-text-slide .item .subtitle {
        font-size: 14px;
    }
    .mc_th-text-slide .item .title {
        padding-top: 14px;
        font-size: 20px;
    }
    .mc_th-text-slide .item .desc {
        font-size: 12px;
    }
    .mc_th-text-slide .media-slide-items {
        flex: 1;
        max-width: 1118px;
    }
    .mc_th-text-slide .slide-item {
        display: none;
    }
    .mc_th-text-slide .slide-item.active {
        display: block;
    }
    .mc_th-text-slide .slide-item.animating .slide-ani {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
    .mc_th-text-slide .slide-item .content {
        left: 64px;
        top: 50%;
        transform: translateY(-50%);
        align-items: flex-start;
    }
    .mc_th-text-slide .slide-item .slide-ani {
        opacity: 0;
        transform: scale(0.95) translateY(5rem);
        transition: transform 0.5s ease-in-out 0.5s;
        transition-property: opacity, transform;
    }
    .mc_th-text-slide .slide-item .subtitle {
        font-size: 26px;
        color: #ffffff;
    }
    .mc_th-text-slide .slide-item .subtitle .image {
        height: var(--image-height);
        width: auto;
        max-width: none;
        object-fit: contain;
        position: absolute;
        left: -2px;
        bottom: -1px;
    }
    .mc_th-text-slide .slide-item .title {
        font-size: 48px;
        color: #ffffff;
    }
    .mc_th-text-slide .slide-item .icons-wrap {
        padding: 8px 0 14px;
        gap: 15px;
    }
    .mc_th-text-slide .slide-item .icons-wrap .image {
        max-height: 64px;
        width: auto;
        object-fit: contain;
    }
    .mc_th-text-slide .slide-item .btn-group {
        padding-top: 46px;
    }
    .mc_th-text-slide .slide-item .more-btn {
        height: 31px;
        font-size: 16px;
        padding: 0 20px;
        background-color: #d30000;
        color: #ffffff;
        transition: background-color 0.3s;
    }
    .mc_th-text-slide .slide-item .more-btn:hover {
        background-color: #000000;
    }
    @media screen and (max-width: 1023px) {
        .mc_th-text-slide {
            padding: 0.9375rem 0;
        }
        .mc_th-text-slide .slide-content {
            gap: 0 0.3125rem;
            flex-direction: column;
            overflow: hidden;
        }
        .mc_th-text-slide .slide-desc {
            margin-top: 0.3125rem;
            padding: 0.875rem 1rem;
            font-size: 0.625rem;
        }
        .mc_th-text-slide .slide-desc > .image {
            max-height: 9.0625rem;
            height: 61%;
            top: 1rem;
            right: 0.65625rem;
        }
        .mc_th-text-slide .text-slide-items {
            width: 100%;
            gap: 0.15625rem;
            padding: 0.15625rem;
            white-space: nowrap;
            overflow-x: auto;
            flex-direction: row;
            align-items: stretch;
        }
        .mc_th-text-slide .item {
            width: 9.375rem;
            min-width: 9.375rem;
            padding: 0 0.5rem;
            min-height: 3.59375rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .mc_th-text-slide .item:before {
            width: 0.09375rem;
            height: 2.625rem;
            right: 0.25rem;
            margin-top: -1.3125rem;
        }
        .mc_th-text-slide .item.active {
            background-color: #d30000;
        }
        .mc_th-text-slide .item.active:before {
            transform: scaleY(1);
        }
        .mc_th-text-slide .item .subtitle {
            font-size: 0.625rem;
        }
        .mc_th-text-slide .item .title {
            padding-top: 0.4375rem;
            font-size: 0.75rem;
        }
        .mc_th-text-slide .item .desc {
            font-size: 0.5rem;
        }
        .mc_th-text-slide .media-slide-items {
            flex: none;
            width: 100%;
            max-width: 100%;
            aspect-ratio: 1.43;
        }
        .mc_th-text-slide .slide-item .content {
            width: 100%;
            left: 0;
            top: auto;
            bottom: 0;
            transform: translateY(0);
            padding: 0 6rem 0.75rem 0.9375rem;
        }
        .mc_th-text-slide .slide-item .subtitle {
            font-size: 0.6875rem;
            color: #ffffff;
        }
        .mc_th-text-slide .slide-item .subtitle .image {
            height: 0.6875rem;
            left: -0.0625rem;
        }
        .mc_th-text-slide .slide-item .title {
            font-size: 1.25rem;
        }
        .mc_th-text-slide .slide-item .icons-wrap {
            padding: 0.25rem 0 0;
            gap: 0.46875rem;
        }
        .mc_th-text-slide .slide-item .icons-wrap .image {
            max-height: 2.1875rem;
            width: auto;
            object-fit: contain;
        }
        .mc_th-text-slide .slide-item .btn-group {
            padding-top: 0;
            position: absolute;
            right: 0.6875rem;
            bottom: 0.875rem;
        }
        .mc_th-text-slide .slide-item .more-btn {
            height: 1.4375rem;
            font-size: 0.625rem;
            padding: 0 0.5625rem;
        }
    }
    {% render 'page-wrap-style' %}
</style>
<div class="mc_th-text-slide section--page" id="{{ section.id }}-slide">
    {%- render 'section-title', info: ss, class: 'flex-center-col' -%}
    <div class="slide-content page-width flex-center">
        <animate-element class="text-slide-items hide-scroll-bar h-full flex-column" data-animate="fade-in">
            {%- for block in section.blocks -%}
                {%- liquid
                    assign bs = block.settings
                    assign is_active = false
                    if ss.mode_type == 'click'
                      assign is_active = forloop.first
                    else
                      if forloop.index == ss.display_position
                        assign is_active = true
                      endif
                    endif
                -%}
                <div node-name="tab"
                     data-proxy="tab"
                     data-index="{{ forloop.index0 }}"
                     class="item w-full cursor-default relative{% if is_active %} active{% endif %}">
                    <div class="subtitle fw-700 lh-2">{{ bs.subtitle }}</div>
                    <div class="title lh-1 fw-600">{{ bs.title }}</div>
                    <div class="desc lh-3">{{ bs.intro }}</div>
                </div>
            {%- endfor -%}
        </animate-element>
        <div class="media-slide-items">
            {%- for block in section.blocks -%}
                {%- liquid
                    assign bs = block.settings
                    assign is_active = false
                    if ss.mode_type == 'click'
                      assign is_active = forloop.first
                    else
                      if forloop.index == ss.display_position
                        assign is_active = true
                      endif
                    endif
                -%}
                <animate-element
                    node-name="panel"
                    data-repeat
                    class="slide-item w-full h-full relative{% if is_active %} active{% endif %}">
                    {%- render 'global-image',
                        image: bs.pc_image,
                        image_size: 1000
                    -%}
                    <div class="content flex-column absolute">
                        {%- if bs.subhead != blank -%}
                            <div class="subtitle slide-ani flex-left relative" style="--image-height: {{ bs.decorate_image_height }}px;">
                                <span class="relative lh-4 z-1"
                                      style="color: {{ bs.subhead_color }};">{{ bs.subhead }}</span>
                                {%- if bs.subhead_decorate_image != blank -%}
                                    {%- render 'global-image', image: bs.subhead_decorate_image, image_size: 300 -%}
                                {%- endif -%}
                            </div>
                        {%- endif -%}
                        {%- if bs.head != blank -%}
                            <div class="title slide-ani fw-600 lh-2" style="color: {{ bs.head_color }};">{{ bs.head }}</div>
                        {%- endif -%}
                        {%- capture icon_code -%}
                            {%- for v in (1..4) -%}
                                {%- assign icon = 'icon' | append: v -%}
                                {%- if bs[icon] != blank -%}
                                    {%- render 'global-image', image: bs[icon], image_size: 300, media_type: 'icon' -%}
                                {%- endif -%}
                            {%- endfor -%}
                        {%- endcapture -%}
                        {%- if icon_code != blank -%}
                            <div class="icons-wrap slide-ani flex-left">
                                {{ icon_code }}
                            </div>
                        {%- endif -%}
                        {%- if bs.show_button -%}
                            <div class="btn-group slide-ani flex-left">
                                <a href="{{ bs.button_url }}"
                                   style="--color: {{ bs.button_color }}; --background: {{ bs.button_bg_color }};"
                                   class="more-btn flex-center lh-2">{{ bs.button_text }}</a>
                            </div>
                        {%- endif -%}
                    </div>
                </animate-element>
            {%- endfor -%}
        </div>
    </div>
    <div class="page-width w-full flex-center">
        <div class="slide-desc relative w-full lh-2">
            {%- render 'global-image', image: ss.slide_desc_background_image, image_size: 600, class: 'absolute' -%}
            {%- for block in section.blocks -%}
                {%- assign bs = block.settings -%}
                <div node-name="desc" class="desc relative{% if forloop.first %} active{% endif %} z-1 w-full">
                    {{ bs.slide_desc }}
                </div>
            {%- endfor -%}
        </div>
    </div>
</div>
{%- if section.blocks.size > 1 and ss.mode_type == 'click' -%}
    <script>
        $heybike.ready(() => {
            const node = document.getElementById('{{ section.id }}-slide');
            let current = 0;
            const {nodeList} = $heybike.tabSwitch({
                root: node,
                device: 'mobile',
                cb: ({index}) => {
                    [].concat(nodeList.desc).forEach((elem, i) => {
                       elem.classList.toggle('active', index === i);
                    });
                }
            });
        });
    </script>
{%- endif -%}
{% schema %}
{
  "name": "MC Th Text Slide",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Th Text Slide"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "Title font style",
      "options": [
        {
          "label": "Normal",
          "value": "normal"
        },
        {
          "label": "italic",
          "value": "italic"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title Bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Slide"
    },
    {
      "type": "color",
      "id": "slide_card_bg_color",
      "label": "Slide card background color",
      "default": "#131313"
    },
    {
      "type": "color",
      "id": "slide_active_color",
      "label": "Slide active color",
      "default": "#d30000"
    },
    {
      "type": "color",
      "id": "slide_text_color",
      "label": "Slide text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "slide_desc_color",
      "label": "Slide desc color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "slide_desc_background_image",
      "label": "Slide desc background image"
    },
    {
      "type": "select",
      "id": "mode_type",
      "label": "Mode type",
      "options": [
        {
          "label": "Click",
          "value": "click"
        },
        {
          "label": "Setting",
          "value": "setting"
        }
      ],
      "default": "click"
    },
    {
      "type": "number",
      "id": "display_position",
      "label": "Display position",
      "default": 1,
      "visible_if": "{{ section.settings.mode_type == 'setting' }}"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide card",
      "settings": [
        {
          "type": "header",
          "content": "Menu"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Menu subtitle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Menu title"
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Menu intro"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mb_image",
          "label": "Mobile image"
        },
        {
          "type": "richtext",
          "id": "subhead",
          "label": "Subtitle"
        },
        {
          "label": "Subtitle decorate image",
          "type": "image_picker",
          "id": "subhead_decorate_image"
        },
        {
          "type": "range",
          "id": "decorate_image_height",
          "label": "Decorate image height",
          "min": 10,
          "max": 80,
          "step": 1,
          "unit": "px",
          "default": 18
        },
        {
          "type": "color",
          "id": "subhead_color",
          "label": "Subtitle color",
          "default": "#ffffff"
        },
        {
          "type": "richtext",
          "id": "head",
          "label": "Title"
        },
        {
          "type": "color",
          "id": "head_color",
          "label": "Title color",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Icon"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "image_picker",
          "id": "icon1",
          "label": "Icon #1"
        },
        {
          "type": "image_picker",
          "id": "icon2",
          "label": "Icon #2"
        },
        {
          "type": "image_picker",
          "id": "icon3",
          "label": "Icon #3"
        },
        {
          "type": "image_picker",
          "id": "icon4",
          "label": "Icon #4"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Show button",
          "default": false
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Learn more >"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button url"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button background color",
          "default": "#D30000"
        },
        {
          "type": "header",
          "content": "Intro"
        },
        {
          "type": "richtext",
          "id": "slide_desc",
          "label": "Slide desc"
        }
      ]
    }
  ]
}
{% endschema %}
