<style>
    .mc_discount-code {
        width: 100%;
        min-height: 20px;
        border-radius: 5px;
    {%- if info.bg_color != blank -%} background-color: {{ info.bg_color }};
    {%- endif -%} overflow: hidden;
        position: relative;
        margin: {{ info.top }}px 0 {{ info.bottom }}px 0;
    }

    {%- if info.bg_image != blank -%}
    .mc_discount-code .image {
        width: 100%;
        aspect-ratio: var(--aspect-ratio);
        object-fit: contain;
    }

    {%- endif -%}

    .mc_discount-code .sales-info {
        padding: 16px {{ info.padding_right | divided_by: 19.2 }}vw 16px {{ info.padding_left | divided_by: 19.2 }}vw;
        color: {{ info.copy_text_color }};
        font-size: 12px;
        font-weight: 400;
        line-height: 1.2;
        position: absolute;
        z-index: 2;
        height: 100%;
        width: 100%;
        top: 0;
        left: 0;
    }

    .mc_discount-code .sales-info .discount-text {
        font-size: 25px;
        font-weight: 700;
        color: {{ info.discount_text_color }};
    }

    .mc_discount-code .sales-info .discount-code {
        cursor: pointer;
        font-size: 18px;
    }

    .mc_discount-code .sales-info .discount-code .success-icon {
        display: none;
        width: 20px;
        height: 20px;
        margin-right: 5px;
    }

    .mc_discount-code .sales-info .discount-code .success-icon .svg-icon {
        width: 100%;
        height: 100%;
    }

    .mc_discount-code .sales-info .discount-code:hover .code {
        text-decoration: underline;
    }

    .mc_discount-code .sales-info .code {
        font-weight: 700;
        margin-top: 5px;
        color: {{ info.discount_code_color }};
    }

    .mc_discount-code .sales-info .discount-code.disabled {
        flex-direction: row;
    }

    .mc_discount-code .sales-info .discount-code.disabled .code {
        display: none;
    }

    .mc_discount-code .sales-info .discount-code.disabled .success-icon {
        display: block;
    }

    .mc_discount-code .sales-info .discount-code.disabled .copy {
        cursor: not-allowed;
        color: {{ info.copy_success_color }};
    }

    @media screen and (max-width: 768px) {
        .mc_discount-code {
            width: 100%;
            border-radius: 0.3125rem;
        }

        .mc_discount-code .sales-info {
            padding: 12px {{ info.mb_padding_right }}px 12px {{ info.mb_padding_left }}px;
        }

        .mc_discount-code .sales-info .discount-text {
            font-size: 20px;
        }

        .mc_discount-code .sales-info .discount-code {
            cursor: pointer;
            font-size: 15px;
        }
    }

    .mc_discount-code .countdown--text .icon {
        width: 16px;
        height: 16px;
    }

    .mc_discount-code .countdown--text {
        padding-top: 8px;
        font-size: 14px;
        gap: 8px;
    }

    .mc_discount-code .countdown--bar {
        gap: 0 18px;
    }

    .mc_discount-code .countdown--bar .num {
        width: 100%;
        color: {{ ts.countdown_num_color }};
        font-size: 18px;
        font-weight: 600;
        text-align: center;
        box-sizing: border-box;
        line-height: 1.2;
        border: 0 none;
        background: none;
        transform: translateY(3px);
    }

    .mc_discount-code .countdown--bar .num:disabled {
        opacity: 1;
    }

    @media screen and (max-width: 768px) {
        .mc_discount-code .countdown--text {
            padding-top: 6px;
            font-size: 12px;
            gap: 6px;
        }
        .mc_discount-code .countdown--text .icon {
            width: 14px;
            height: 14px;
        }
    }
</style>
<div class="mc_discount-code" id="{{ section.id }}-sales">
    {%- if info.bg_image != blank -%}
        {% render 'global-image',
            image: info.bg_image,
            show_size: true
        %}
    {%- endif -%}
    <div class="sales-info flex-between">
        <div class="discount-text">
            {{ info.discount_text }}
        </div>
        <div class="discount-code flex-center-col">
            <div class="success-icon">
                <svg class="svg-icon" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
                    <path
                        d="M512 1013.76c-277.11488 0-501.76-224.64512-501.76-501.76S234.88512 10.24 512 10.24s501.76 224.64512 501.76 501.76-224.64512 501.76-501.76 501.76z m0-51.02592c248.9344 0 450.73408-201.79968 450.73408-450.73408 0-248.9344-201.79968-450.73408-450.73408-450.73408-248.9344 0-450.73408 201.79968-450.73408 450.73408 0 248.9344 201.79968 450.73408 450.73408 450.73408z m-89.22112-361.0112c60.928-74.33216 195.9424-222.67904 382.08512-340.16256l15.616 37.4784c-171.14624 161.8944-311.36768 322.23744-355.45088 438.76864l-256.8704-201.6 65.82784-54.48704 148.7872 119.99744z"
                        fill="{{ info.copy_success_color }}"></path>
                </svg>
            </div>
            <div class="copy" id="{{ section.id }}-copy">{{ info.copy_text }}</div>
            <div class="code">{{ info.discount_code }}</div>
            <countdown-timer
                cycle-duration="{{ info.duration }}"
                data-type="text"
                data-store="{{ 'now' | date: '%Y-%m-%dT%H:%M:%S' }}"
                data-date="{{ info.countdown_start_date }}">
                <div class="countdown--text flex-center">
                    <svg class="icon" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="48" height="48">
                        <path
                            d="M1008.185895 221.122824c-57.098377-90.39743-136.996106-165.195304-230.893437-216.293851-19.299451-10.499702-43.398766-3.299906-53.79847 15.999545s-3.299906 43.398766 15.899548 53.798471c82.097666 44.598732 151.795685 109.996873 201.694266 188.994627 7.599784 11.999659 20.39942 18.499474 33.599045 18.499474 7.299792 0 14.599585-1.999943 21.199397-6.099827 18.499474-11.799665 24.099315-36.298968 12.299651-54.898439zM468.201245 336.919532c-21.899377 0-39.698871 17.799494-39.698871 39.698872v175.994996c0.299991 10.699696 4.899861 20.299423 11.999659 27.199227l79.097751 90.097439c7.799778 8.899747 18.799466 13.499616 29.799153 13.499616 9.299736 0 18.599471-3.299906 26.199255-9.899718 16.499531-14.499588 18.099485-39.498877 3.599898-55.998408l-71.397971-81.297689V376.618404c0.099997-21.899377-17.699497-39.698871-39.598874-39.698872z"
                            fill="currentColor"></path>
                        <path
                            d="M507.900117 85.226687V43.127884c0-21.899377-17.799494-39.698871-39.698872-39.698871s-39.698871 17.799494-39.698871 39.698871v43.998749c-28.299196 3.099912-56.698388 8.79975-84.897587 17.399506-247.99295 74.897871-388.788948 337.590403-313.891077 585.583353 6.399818 20.999403 28.49919 32.799068 49.498593 26.499246 20.999403-6.299821 32.899065-28.49919 26.499247-49.498592C43.413321 461.016004 160.409995 242.72221 366.504136 180.523978c206.094141-62.198232 424.387936 54.698445 486.586168 260.792586 62.298229 206.094141-54.698445 424.387936-260.792587 486.586168-148.495779 44.898724-309.491202-2.399932-410.088342-120.496575-14.199596-16.699525-39.298883-18.699468-55.998408-4.499872-16.699525 14.199596-18.699468 39.298883-4.499872 55.998408C212.608511 965.301669 344.004776 1024 479.500924 1024c45.298712 0 91.09741-6.599812 135.796139-20.099429 247.99295-74.997868 388.68895-337.6904 313.79108-585.583353C870.7898 225.12271 698.494698 97.026352 507.900117 85.226687z"
                            fill="currentColor"></path>
                    </svg>
                    {%- if info.countdown_text != blank -%}
                        <span class="hidden md:block">{{ info.countdown_text }}</span>
                    {%- endif -%}
                    <span node-name="text"></span>
                </div>
            </countdown-timer>
        </div>
    </div>
</div>
<script>
    (function () {
        const node = document.getElementById('{{ section.id }}-copy');
        const copyText = (text) => {
            const node = document.createElement('INPUT');
            node.style.cssText = 'position: fixed; top: -100000px;';
            document.body.appendChild(node);
            node.value = text;
            node.focus();
            node.select();
            let range = document.createRange();
            range.selectNodeContents(node);
            let sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
            node.setSelectionRange(0, 9999);
            document.execCommand('copy');
            node.blur();
            document.body.removeChild(node);
        };
        const parent = node.parentNode;
        parent.addEventListener('click', () => {
            if (parent.classList.contains('disabled')) {
                return false;
            }
            copyText('{{ info.discount_code }}');
            node.innerHTML = '{{ info.copy_success }}';
            parent.classList.add('disabled');
            setTimeout(() => {
                node.innerHTML = '{{ info.copy_text }}';
                parent.classList.remove('disabled');
            }, 2000);
        });
    })();
</script>
