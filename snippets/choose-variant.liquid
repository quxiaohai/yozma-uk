{%- liquid
    assign cid = section.id | split: '__' | last
    assign color_label_list = 'general.label.color' | t | replace: ', ', ',' | downcase | split: ','
    assign size_label_list = 'general.label.size' | t | replace: ', ', ',' | downcase | split: ','
-%}
{%- unless product.has_only_default_variant -%}
    <div class="choose-variant">
        {%- for option in product.options_with_values -%}
            {% liquid
                assign option_downcase = option.name | downcase
                assign resolved_option_selector_style = 'dropdown'

                assign swatch_count = option.values | map: 'swatch' | compact | size

                if swatch_count > 0
                    assign resolved_option_selector_style = 'swatch'
                endif

                if swatch_count == 0 and color_label_list contains option_downcase
                    assign resolved_option_selector_style = 'swatch'
                endif
            %}
            <fieldset class="variant-picker__option choose-variant-{{ resolved_option_selector_style }}">
            {%- assign name = 'product-' | append: product.id | append: cid | append: '-option' | append: option.position -%}
            {%- unless hide_label -%}
                <div class="variant-picker__option-info">
                    <div class="h-stack gap-2">
                        <legend class="text-subdued fw-700">{{ option.name }}:</legend>
                        <span node-name="{{ name }}" class="fw-700 variant-text">{{ option.selected_value }}</span>
                    </div>
                </div>
            {%- endunless -%}
            {%- if resolved_option_selector_style == 'dropdown' -%}
                {%- capture popover_id -%}popover-variant-picker-{{ section.id }}-{{ product.id }}-{{ option.position }}{%- endcapture -%}

                <div class="relative">
                    <button type="button" class="select" aria-controls="{{ popover_id }}" aria-expanded="false">
                        <span node-name="{{ name }}">{{- option.selected_value -}}</span>
                        {%- render 'icon' with 'chevron-bottom', class: 'select-chevron' -%}
                    </button>

                    <x-popover id="{{ popover_id }}" class="popover" initial-focus="[aria-selected='true']"
                               close-on-listbox-select anchor-horizontal="start" anchor-vertical="end">
                        <p class="h5" slot="title">{{ option.name }}</p>
                        <div data-option-selector class="popover-listbox">
                            {%- for option_value in option.values -%}
                                {%- if hide_sold_out_variants == false or option_value.available or option_value.selected -%}
                                    <label
                                        class="popover-listbox__option {% unless option_value.available %}is-disabled{% endunless %}"
                                        for="{{ name }}-{{ option_value.id }}">
                                        <input class="sr-only"
                                               type="radio"
                                               onchange="$heybike.emit('{{ emit }}', {vm: this, id: {{ option_value.variant.id }}, price: '{{ option_value.variant.price | money }}', originalPrice: '{{ option_value.variant.compare_at_price | money }}', name: '{{ option_value.name }}', image: '{{ option_value.variant.featured_image | image_url: width: 1200 }}'})"
                                               id="{{ name }}-{{ option_value.id }}"
                                               name="{{ name }}"
                                               {% if option_value.product_url != blank %}data-product-url="{{ option_value.product_url | escape }}"{% endif %}
                                               data-option-position="{{ option.position }}"
                                               value="{{ option_value.id }}" {% if option_value.selected %}checked{% endif %}>

                                        {{- option_value.name -}}
                                    </label>
                                {%- endif -%}
                            {%- endfor -%}
                        </div>
                    </x-popover>
                </div>
            {%- else -%}
                <div
                    class="variant-picker__option-values {% if block.settings.stack_blocks %}wrap{% else %}scroll-area bleed sm:unbleed{% endif %} {% if resolved_option_selector_style == 'swatch' and settings.color_swatch_style == 'rectangle' %}variant-picker__option-values--color gap-4{% else %}gap-2{% endif %}">
                    {% liquid
                        for option_value in option.values
                            case resolved_option_selector_style
                                when 'variant_image'
                                    render 'option-value', type: 'thumbnail', emit: emit, option_value: option_value, param_name: name, option_position: option.position, id_prefix: forloop.index, bordered: true
                                when 'swatch'
                                    render 'option-value', type: 'swatch', emit: emit, option_value: option_value, param_name: name, option_position: option.position, id_prefix: forloop.index
                                when 'block'
                                    render 'option-value', type: 'block', emit: emit, option_value: option_value, param_name: name, option_position: option.position, id_prefix: forloop.index
                                when 'block_swatch'
                                    render 'option-value', type: 'block', emit: emit, option_value: option_value, param_name: name, option_position: option.position, show_swatch: true, id_prefix: forloop.index
                            endcase
                        endfor
                    %}
                </div>
                </fieldset>
            {%- endif -%}
        {%- endfor -%}
    </div>
{%- endunless -%}