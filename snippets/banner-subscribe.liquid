{% assign secId = section.id | split: '__' | last %}
<style>
    .{{ secId }}-subscribe {
        width: 100%;
        padding: {{ info.top | divided_by: 19.2 }}vw {{ info.right | divided_by: 19.2 }}vw {{ info.bottom | divided_by: 19.2 }}vw {{ info.left | divided_by: 19.2 }}vw;
    }

    {%- if info.show_intro -%}
    .{{ secId }}-subscribe .subscribe-remark {
        font-size: {{ info.pc_intro_size }};
        text-align: {{ info.info_align }};
        color: {{ info.intro_color }};
        padding-bottom: {{ info.pc_intro_bottom }};
        word-break: break-word;
        width: 100%;
    }

    .{{ secId }}-subscribe .subscribe-remark strong {
        color: {{ info.intro_bold_color }};
    }

    {%- endif -%}

    .{{ secId }}-subscribe.style-2 .form-wrap {
        padding: 3px;
        border: 0 none !important;
        background-color: #FFFFFF;
        height: {% if info.input_h > 0 %}{{ info.input_h }}px{% else %} 60px{% endif %};
    }

    .{{ secId }}-subscribe.style-2 .form-wrap .btn {
        padding: 0 24px;
        font-weight: 400;
    }

    .{{ secId }}-subscribe .subscribe-status {
        font-weight: bold;
        font-size: 20px;
        padding: 20px 0;
        color: {{ info.sub_success_color }};
        display: none;
    }

    .{{ secId }}-subscribe .subscribe-status.show {
        display: block;
    }

    .{{ secId }}-subscribe .subscribe-wrap {
        width: {% if info.input_w > 0 %}{{ info.input_w }}px{% else %} 466px{% endif %};
    }

    .{{ secId }}-subscribe .subscribe-wrap.hidden {
        display: none;
    }

    .{{ secId }}-subscribe .form-content {
        position: relative;
        width: 100%;
        text-align: center;
    }

    .{{ secId }}-subscribe .form-content .error .item-error {
        opacity: 1;
    }

    .{{ secId }}-subscribe .form-content .error-wrap {
        position: relative;
        width: 0;
        height: 0;
        z-index: 1;
    }

    .{{ secId }}-subscribe .form-content .item-error {
        border-radius: 4px;
        box-shadow: rgba(0, 0, 0, 0.26) 1px 1px 4px 0;
        border: 1px solid rgb(208, 51, 31);
        background-color: rgb(255, 244, 240);
        pointer-events: none;
        font-size: 14px;
        padding: 8px;
        color: rgb(208, 51, 31);
        position: absolute;
        left: -18px;
        top: 10px;
        white-space: nowrap;
        opacity: 0;
        transition: all 0.5s;
    }

    .{{ secId }}-subscribe .form-content .item-error:before, .{{ secId }}-subscribe .form-content .item-error:after {
        content: "";
        width: 0;
        height: 0;
        border: 8px solid transparent;
        border-bottom-color: rgb(208, 51, 31);
        position: absolute;
        left: 10px;
        top: -16px;
        z-index: 1;
    }

    .{{ secId }}-subscribe .form-content .item-error:after {
        border-bottom-color: rgb(255, 244, 240);
        top: -15px;
        z-index: 2;
    }

    .{{ secId }}-subscribe .form-wrap {
        width: 100%;
