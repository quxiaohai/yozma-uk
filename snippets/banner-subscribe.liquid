<div id="{{ section.id }}-subscribe"
     class="{{ secId }}-subscribe {{ info.pc_align }}{% if style %} {{ style }}{% endif %}">
    <div class="subscribe-wrap" node-name="wrap">
        {%- if info.show_intro -%}
            <div class="subscribe-remark">
                {{ info.intro }}
            </div>
        {%- endif -%}
        <form class="form-content" node-name="form">
            <label class="form-wrap flex-between" node-name="input">
                <input type="text" node-name="email" class="u-input" placeholder="{{ info.input_placeholder }}"/>
                {%- if info.sub_btn_align != 'col' -%}
                    <button class="btn" node-name="submit" type="submit">{{ info.sub_btn }}</button>
                {%- endif -%}
                <span class="error-wrap">
                <span class="item-error" node-name="error">{{ info.privacy_required }}</span>
            </span>
            </label>
            {%- if info.show_privacy -%}
                <div class="privacy-info {% if info.privacy_checked %}checked{% endif %} flex-top" node-name="privacy">
                    <div class="checkbox flex-center">
                        <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" width="10.707" height="7.511"
                             viewBox="0 0 10.707 7.511">
                            <path d="M-11467.566,874.83l3.55,3.55,6.45-6.451"
                                  transform="translate(11467.92 -871.575)" fill="none"
                                  stroke="#fff" stroke-width="1"></path>
                        </svg>
                    </div>
                    <div class="text flex-bottom">
                        <div class="error-wrap">
                            <div class="item-error">{{ info.privacy_required }}</div>
                        </div>
                        {{ info.privacy_text }}
                    </div>
                </div>
            {%- endif -%}
            {%- if info.sub_btn_align == 'col' -%}
                <button class="col-btn" node-name="submit" type="submit">{{ info.sub_btn }}</button>
            {%- endif -%}
        </form>
    </div>
    {% comment %}<div class="subscribe-status" node-name="status">{{ info.sub_success }}</div>{% endcomment %}
</div>
<script>
    (function () {
        const node = document.getElementById('{{ section.id }}-subscribe');
        const nodeList = $heybike.getNodeList(node);
        nodeList.privacy && nodeList.privacy.addEventListener("click", (ev) => {
            if (ev.target.tagName.toLocaleLowerCase() === "a") {
                return false;
            }
            ev.preventDefault();
            ev.stopPropagation();
            if (nodeList.privacy.classList.contains("checked")) {
                nodeList.privacy.classList.remove("checked");
            } else {
                nodeList.privacy.classList.add("checked");
                nodeList.privacy.classList.remove("error");
            }
        });

        const isVerifyEmail = (val) => {
            var reg1 = /@([a-zA-Z0-9_-])+(\.[a-zA-Z0-9_-])+/;//防止输入过长的时候，卡死
            var reg2 = /^([a-zA-Z0-9_-]+[_|\_|\.]?)+@([a-zA-Z0-9_-])+(\.[a-zA-Z0-9_-])+/;
            if (reg1.test(val)) {
                return reg2.test(val);
            }
            return false;
        };

        nodeList.email.addEventListener("blur", () => {
            const value = nodeList.email.value.trim();
            if (value === "") {
                nodeList.error.innerHTML = '{{ info.input_empty }}';
                nodeList.input.classList.add("error");
            } else if (!isVerifyEmail(value)) {
                nodeList.error.innerHTML = '{{ info.input_required }}';
                nodeList.input.classList.add("error");
            } else {
                nodeList.input.classList.remove("error");
            }
        });

        nodeList.submit.addEventListener("click", (ev) => {
            ev.stopPropagation();
            ev.preventDefault();
            if (nodeList.form.classList.contains("disabled")) {
                ev.stopPropagation();
                ev.preventDefault();
                return false;
            }
            let isVerify = true;

            const value = nodeList.email.value.trim();

            if (value === "") {
                nodeList.error.innerHTML = '{{ info.input_empty }}';
                nodeList.input.classList.add("error");
                isVerify = false;
            } else if (!isVerifyEmail(value)) {
                nodeList.error.innerHTML = '{{ info.input_required }}';
                nodeList.input.classList.add("error");
                isVerify = false;
            }

            if (!nodeList.privacy.classList.contains("checked")) {
                nodeList.privacy.classList.add("error");
                isVerify = false;
            }

            if (!isVerify) {
                ev.stopPropagation();
                ev.preventDefault();
            }
            nodeList.form.classList.add("disabled");
        });
    })();
</script>