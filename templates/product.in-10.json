            "media_ratio": "",
            "mb_media_ratio": "",
            "show_subhead": true,
            "subhead": "Smooth rides with engineered shocks",
            "subhead_color": "#ff0000",
            "head": "Ride Harder, Land Smoother",
            "head_color": "#ffffff",
            "head_gradient_color": "",
            "text": "<p>Equipped with a high-stiffness nitrogen air shock and independent suspension, combined with <strong>146 N·m torque</strong> and heavy-duty hydraulic brakes for smooth, controlled, and confident riding on rough terrain.</p>",
            "text_color": "#b2b2b2",
            "text_bold_color": "#ff0000"
          }
        },
        "slide_bk4jPz": {
          "type": "slide",
          "settings": {
