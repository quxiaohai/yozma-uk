    "faq_NjtRGW": {
      "type": "faq",
      "blocks": {
        "item_3CNzMi": {
          "type": "item",
          "settings": {
            "title": "1. What is the Spring Sale period?",
            "content": "<p>The Spring Sale runs from <strong>February 27 to March 15</strong>.</p>"
          }
        },
        "item_4mT3Pq": {
          "type": "item",
          "settings": {
            "title": "2. Which models are included in this Spring Sale?",
            "content": "<p>This Spring Sale is <strong>available for the YOZMA IN 10 model only</strong>.<br/><br/>Other models are not eligible for this promotion.</p>"
          }
        },
        "item_QMHbRc": {
          "type": "item",
          "settings": {
            "title": "3. Do I get a free gift when purchasing a bike?",
            "content": "<p>Yes. <strong>Every purchase of a complete bike includes a FREE bike bag.</strong></p>"
          }
        },
        "item_GB6DXn": {
          "type": "item",
          "settings": {
            "title": "4. How do free gifts work based on order value?",
            "content": "<p>Free gifts are determined by your <strong>order subtotal before tax</strong>:</p><ul><li>Orders over <strong>$1,499</strong>: FREE Riding Gloves</li><li>Orders over <strong>$2,399</strong>: FREE Helmet</li><li>Orders over <strong>$2,999</strong>: FREE Riding Safety Gear Set (Includes Helmet + Riding Gloves + Small Accessories)</li></ul>"
          }
        },
        "item_jPNtWR": {
          "type": "item",
          "settings": {
            "title": "5. Can I receive multiple free gifts?",
            "content": "<p>No. <strong>Free gifts do not stack.</strong><br/><br/>You will receive <strong>only the highest-tier gift</strong> based on your order value.</p>"
          }
        },
        "item_nzectQ": {
          "type": "item",
          "settings": {
            "title": "6. What are “small accessories”?",
            "content": "<p>Small accessories may include items such as <strong>keychains or small riding gear</strong>.<br/><br/>Accessories are <strong>sent at random</strong>.</p>"
          }
        },
        "item_RYmhMd": {
          "type": "item",
          "settings": {
            "title": "7. Is this promotion available while supplies last?",
            "content": "<p>Yes. All free gifts are available <strong>while supplies last</strong>.</p>"
          }
        },
        "item_G3YHFt": {
          "type": "item",
          "settings": {
            "title": "8. Can this promotion be combined with other discounts or offers?",
            "content": "<p>This promotion cannot be combined with any other promotions or discounts. Only one offer may be applied per order.</p>"
          }
        },
        "item_pf66DX": {
          "type": "item",
          "settings": {
            "title": "9. When will the free gifts be shipped?",
            "content": "<p>Free gifts earned through this promotion are <strong>expected to ship in mid-March</strong>.<br/><br/>They may be shipped <strong>separately</strong> from the bike.</p>"
          }
        }
      },
