            "media_ratio": "",
            "mb_media_ratio": "",
            "show_subhead": true,
            "subhead": "Instant power when you twist the throttle",
            "subhead_color": "#ff0000",
            "head": "Raw Power, Pure Speed",
            "head_color": "#ffffff",
            "head_gradient_color": "",
            "text": "<p>The <strong>2600W </strong>mid-drive motor drives you smoothly up to <strong>20 Km/h</strong>, delivering precise control and rock-solid stability through every turn and jump. Twist the throttle and experience true dirt bike performance—pure adrenaline, total confidence.</p>",
            "text_color": "#b2b2b2",
            "text_bold_color": "#ff0000"
          }
        },
        "slide_mJXatN": {
          "type": "slide",
          "settings": {
            "title": "",
