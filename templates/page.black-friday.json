    "faq_WdNy7m": {
      "type": "faq",
      "blocks": {
        "item_Yir7Yt": {
          "type": "item",
          "settings": {
            "title": "What is the Black Friday event about?",
            "content": "<p>During Nov 14 – Dec 8, customers can participate in <strong>four main activities</strong>: <br/>1) Spin Wheel rewards, <br/>2) Free e-bike giveaway, <br/>3) Cash back for eligible orders <br/>4) Free gifts with purchase.</p>"
          }
        },
        "item_F8VdHm": {
          "type": "item",
          "settings": {
            "title": "What should I do before I place my order?",
            "content": "<p>Before placing your order, please confirm that you are<strong>14 </strong>years of age or older. When riding, always follow local laws and regulations, wear a helmet, and prioritize safety at all times.</p>"
          }
        },
        "item_GPUUph": {
          "type": "item",
          "settings": {
            "title": "How does the Spin Wheel activity work?",
            "content": "<p>Enter your email to get a Spin Wheel chance, win a corresponding reward, and use any discount codes at checkout to claim your prize.</p>"
          }
        },
        "item_tPQhcc": {
          "type": "item",
          "settings": {
            "title": "Will my free gifts arrive with my e-bike order?",
            "content": "<p>Gifts shipped with your order or in a separate package, and you can email us if they are delayed.</p>"
          }
        },
        "item_yqgdpr": {
          "type": "item",
          "settings": {
            "title": "How do I know if I won the cash back?",
            "content": "<p>Orders ending with the number 5 win the cash back; winners will be notified by email, and the cash back will be applied to the original order once it is completed—returns or refunds will invalidate the reward.</p>"
          }
        },
        "item_8Lhg7F": {
          "type": "item",
          "settings": {
            "title": "How will I know if I won a free e-bike from the website?",
            "content": "<p>Winners from the website will be <strong>notified by email</strong>, while winners from social media after <strong>Nov 28</strong> will be notified via <strong>direct message</strong>.</p>"
          }
        }
      },
