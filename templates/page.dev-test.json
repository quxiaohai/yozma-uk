    "faq_VMwpEf": {
      "type": "faq",
      "blocks": {
        "item_CezepJ": {
          "type": "item",
          "settings": {
            "title": "What are the requirements for videos?",
            "content": "<ul><li>Must be at least 10 seconds</li><li>Use an actual Yozma e-dirt bike to film</li><li>Video posting time must be after January 1st, 2026</li><li>The interaction rate must reach 3%（[Like+Comment+Share]/Views≥3%）</li><li>The video must be original content and based on TikTok creator dashboard</li><li>Please follow TikTok's Community Guidelines</li></ul>"
          }
        },
        "item_iaij3W": {
          "type": "item",
          "settings": {
            "title": "Who can participate in this event?",
            "content": "<p>Anyone who has access to a Yozma e-dirt bike and meets the requirements can participate,  except for creators who are already collaborating with or officially sponsored by Yozmasport.</p>"
          }
        },
        "item_aJBHGj": {
          "type": "item",
          "settings": {
            "title": "How often does Yozmasport review content?",
            "content": "<p>Submissions received each month will be reviewed by the 10th of the following month.</p>"
          }
        },
        "item_npDmDh": {
          "type": "item",
          "settings": {
            "title": "Is it possible to receive multiple awards?",
            "content": "<ul><li>Every single video/link can only be redeemed for a reward once. (highest video views achieved)</li><li>You can film and upload different videos to get more chances to claim multiple rewards.</li><li>Each account can receive a maximum of 5 rewards per month.</li></ul>"
          }
        },
        "item_8qJnwA": {
          "type": "item",
          "settings": {
            "title": "When will the payment be made?",
            "content": "<ul><li>Rewards will be paid during the last week of the following month for the previous month’s submissions.<br/></li><li>Submitting your screenshot via Submit is considered your official entry, and the submission time is based on when the screenshot is uploaded. All eligible rewards will be processed during the scheduled payout period.</li></ul>"
          }
        },
        "item_4B46Yj": {
          "type": "item",
          "settings": {
            "title": "How do I know my video has been rewarded?",
            "content": "<ul><li>The official email address: event@yozmasport.com<strong> (one and only)</strong> will email you directly for additional details.</li><li>Make sure you provide a valid email address and keep an eye on your mailbox!</li><li>The amount is paid to you without deducting any taxes, duties, tariffs, or other related governmental fees. As required by relevant regulations, you will need to take responsibility for any such charges that may apply.</li><li>Participants must provide a valid PayPal account.  Failure to receive payment or account restrictions will be considered a forfeiture or require an alternative payment method.</li></ul>"
          }
        },
        "item_Tjgjfc": {
          "type": "item",
          "settings": {
            "title": "Disqualification / Fraud Prevention",
            "content": "<p>We may reject claims for purchased/inorganic traffic, bots, repeated/duplicate content, copyright violations, or videos removed/private at the time of verification.</p>"
          }
        }
      },
